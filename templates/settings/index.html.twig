{% extends '_layout/app.html.twig' %}

{% block title %}{{ 'settings.title'|trans }} — {{ 'app.name'|trans }}{% endblock %}
{% block body_controllers %}mercure{% endblock %}
{% block body %}
    <div class="h-screen overflow-hidden app-bg"
         data-controller="sidebar-drawer">

        {# Mobile backdrop #}
        <div data-sidebar-drawer-target="backdrop" data-action="click->sidebar-drawer#backdropClick"
             class="md:hidden fixed inset-0 z-30 bg-black/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-200"
             aria-hidden="true"></div>

        {# Mobile sidebar drawer #}
        <div data-sidebar-drawer-target="drawer"
             class="md:hidden fixed inset-y-0 left-0 z-40 w-64 p-3 -translate-x-full transition-transform duration-200 ease-out">
            {% include '_partials/_sidebar.html.twig' with { _drawerMode: true } %}
        </div>

        <div class="flex h-full flex-col p-3 gap-3">

            {% include '_partials/_topbar.html.twig' with { _showBurger: true } %}

            <div class="flex flex-1 gap-3 overflow-hidden">

                {# Sidebar — desktop #}
                <div class="hidden md:flex">
                    {% include '_partials/_sidebar.html.twig' %}
                </div>

                {# Main content pane — settings #}
                <div class="flex flex-1 overflow-hidden pane">
                    <div class="flex flex-col flex-1 overflow-hidden">

                        {# Pane header #}
                        <div class="flex items-center gap-3 px-6 h-14 border-b border-line shrink-0">
                            <i class="fa-solid fa-gear text-zinc-400" aria-hidden="true"></i>
                            <h1 class="text-base font-semibold text-ink">{{ 'settings.title'|trans }}</h1>
                        </div>

                        {# Scrollable body: section nav + content.
                           IMPORTANT: this grid must have exactly TWO children —
                           the nav and ONE content wrapper. A third child wraps
                           into the 180px nav column on the next grid row. #}
                        <div class="flex-1 overflow-y-auto">
                            <div class="max-w-3xl mx-auto px-6 py-8 grid grid-cols-1 md:grid-cols-[180px_1fr] gap-8">

                                <nav class="space-y-1">
                                    {% set navActive   = 'flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium bg-raised text-ink' %}
                                    {% set navInactive = 'flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-ink-muted hover:bg-hover transition-colors' %}

                                    <a href="{{ path('app_settings_index', { section: 'accounts' }) }}"
                                       class="{{ section == 'accounts' ? navActive : navInactive }}">
                                        <i class="fa-solid fa-at w-4 {{ section == 'accounts' ? 'text-zinc-400' : '' }}" aria-hidden="true"></i>
                                        {{ 'settings.nav.accounts'|trans }}
                                    </a>
                                    <a href="{{ path('app_settings_index', { section: 'labels' }) }}"
                                       class="{{ section == 'labels' ? navActive : navInactive }}">
                                        <i class="fa-solid fa-tag w-4 {{ section == 'labels' ? 'text-zinc-400' : '' }}" aria-hidden="true"></i>
                                        {{ 'settings.nav.labels'|trans }}
                                    </a>
                                    <a href="{{ path('app_settings_index', { section: 'appearance' }) }}"
                                       class="{{ section == 'appearance' ? navActive : navInactive }}">
                                        <i class="fa-solid fa-palette w-4 {{ section == 'appearance' ? 'text-ink-faint' : '' }}" aria-hidden="true"></i>
                                        {{ 'settings.nav.appearance'|trans }}
                                    </a>
                                </nav>

                                {# Single content wrapper — second (and last) grid child #}
                                <div>
                                    {% if section == 'appearance' %}
                                        {% include 'settings/_appearance.html.twig' %}
                                    {% elseif section == 'labels' %}
                                        <section>
                                            <div class="mb-4">
                                                <h2 class="text-sm font-semibold text-ink">{{ 'settings.labels.heading'|trans }}</h2>
                                                <p class="text-xs text-ink-faint mt-0.5">{{ 'settings.labels.subheading'|trans }}</p>
                                            </div>

                                            <div class="rounded-pane border border-line overflow-hidden">
                                                <div id="settings-label-list">
                                                    {% include 'settings/_labels.html.twig' with {
                                                        manageableAccounts: manageableAccounts,
                                                        labelsByAccount: labelsByAccount,
                                                    } %}
                                                </div>
                                            </div>
                                        </section>

                                    {% else %}
                                        <section>
                                            <div class="flex items-center justify-between mb-4">
                                                <div>
                                                    <h2 class="text-sm font-semibold text-ink">{{ 'settings.accounts.heading'|trans }}</h2>
                                                    <p class="text-xs text-ink-faint mt-0.5">{{ 'settings.accounts.subheading'|trans }}</p>
                                                </div>
                                                <button
                                                    type="button"
                                                    data-controller="modal"
                                                    data-action="click->modal#open"
                                                    data-modal-title-value="{{ 'sidebar.accounts.add'|trans }}"
                                                    data-modal-src-value="{{ path('app_account_new') }}"
                                                    class="inline-flex items-center gap-2 px-3 h-9 rounded-lg text-sm font-medium
                                                           bg-accent hover:bg-accent-strong text-white transition-colors cursor-pointer"
                                                >
                                                    <i class="fa-solid fa-plus text-xs" aria-hidden="true"></i>
                                                    {{ 'sidebar.accounts.add'|trans }}
                                                </button>
                                            </div>

                                            <div class="rounded-pane border border-line overflow-hidden">
                                                <div id="settings-account-list">
                                                    {% include 'settings/_accounts.html.twig' with { manageableAccounts: manageableAccounts } %}
                                                </div>
                                            </div>
                                        </section>

                                    {% endif %}
                                </div>

                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
