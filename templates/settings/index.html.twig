{% extends '_layout/app.html.twig' %}

{% block title %}{{ 'settings.title'|trans }} — {{ 'app.name'|trans }}{% endblock %}
{% block body_controllers %}mercure{% endblock %}
{% block body %}
    <div class="h-screen overflow-hidden bg-gradient-to-br from-blue-50 via-slate-100 to-indigo-100 dark:from-slate-950 dark:via-slate-900 dark:to-indigo-950"
         data-controller="sidebar-drawer">

        {# Mobile backdrop #}
        <div data-sidebar-drawer-target="backdrop" data-action="click->sidebar-drawer#backdropClick"
             class="md:hidden fixed inset-0 z-30 bg-black/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-200"
             aria-hidden="true"></div>

        {# Mobile sidebar drawer #}
        <div data-sidebar-drawer-target="drawer"
             class="md:hidden fixed inset-y-0 left-0 z-40 w-64 p-3 -translate-x-full transition-transform duration-200 ease-out">
            {% include '_partials/_sidebar.html.twig' with { _drawerMode: true } %}
        </div>

        <div class="flex h-full flex-col p-3 gap-3">

            {% include '_partials/_topbar.html.twig' with { _showBurger: true } %}

            <div class="flex flex-1 gap-3 overflow-hidden">

                {# Sidebar — desktop #}
                <div class="hidden md:flex">
                    {% include '_partials/_sidebar.html.twig' %}
                </div>

                {# Main content pane — settings #}
                <div class="flex flex-1 overflow-hidden rounded-2xl border border-white/60 dark:border-white/10 bg-white/70 dark:bg-gray-900/60 backdrop-blur-xl shadow-lg shadow-black/5 dark:shadow-black/30">
                    <div class="flex flex-col flex-1 overflow-hidden">

                        {# Pane header #}
                        <div class="flex items-center gap-3 px-6 h-14 border-b border-black/[0.06] dark:border-white/10 shrink-0">
                            <i class="fa-solid fa-gear text-zinc-400" aria-hidden="true"></i>
                            <h1 class="text-base font-semibold text-zinc-800 dark:text-zinc-100">{{ 'settings.title'|trans }}</h1>
                        </div>

                        {# Scrollable body: section nav + content #}
                        <div class="flex-1 overflow-y-auto">
                            <div class="max-w-3xl mx-auto px-6 py-8 grid grid-cols-1 md:grid-cols-[180px_1fr] gap-8">

                                <nav class="space-y-1">
                                    <span class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium
                                                 bg-black/[0.04] dark:bg-white/[0.06] text-zinc-800 dark:text-zinc-100">
                                        <i class="fa-solid fa-at w-4 text-zinc-400" aria-hidden="true"></i>
                                        {{ 'settings.nav.accounts'|trans }}
                                    </span>
                                    <span class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-zinc-400 dark:text-zinc-600 cursor-not-allowed">
                                        <i class="fa-solid fa-sliders w-4" aria-hidden="true"></i>
                                        {{ 'settings.nav.general'|trans }}
                                    </span>
                                </nav>

                                <section>
                                    <div class="flex items-center justify-between mb-4">
                                        <div>
                                            <h2 class="text-sm font-semibold text-zinc-800 dark:text-zinc-100">{{ 'settings.accounts.heading'|trans }}</h2>
                                            <p class="text-xs text-zinc-400 dark:text-zinc-500 mt-0.5">{{ 'settings.accounts.subheading'|trans }}</p>
                                        </div>
                                        <button
                                            type="button"
                                            data-controller="modal"
                                            data-action="click->modal#open"
                                            data-modal-title-value="{{ 'sidebar.accounts.add'|trans }}"
                                            data-modal-src-value="{{ path('app_account_new') }}"
                                            class="inline-flex items-center gap-2 px-3 h-9 rounded-lg text-sm font-medium
                                                   bg-blue-600 hover:bg-blue-700 text-white transition-colors cursor-pointer"
                                        >
                                            <i class="fa-solid fa-plus text-xs" aria-hidden="true"></i>
                                            {{ 'sidebar.accounts.add'|trans }}
                                        </button>
                                    </div>

                                    <div class="rounded-2xl border border-black/[0.06] dark:border-white/10 overflow-hidden">
                                        <div id="settings-account-list">
                                            {% include 'settings/_accounts.html.twig' with { manageableAccounts: manageableAccounts } %}
                                        </div>
                                    </div>
                                </section>
                                <section>
                                    <div class="flex items-center justify-between mb-4">
                                        <div>
                                            <h2 class="text-base font-semibold text-zinc-800 dark:text-zinc-100">{{ 'settings.labels.heading'|trans }}</h2>
                                            <p class="text-xs text-zinc-400 dark:text-zinc-500 mt-0.5">{{ 'settings.labels.subheading'|trans }}</p>
                                        </div>
                                    </div>

                                    <div class="rounded-2xl border border-black/[0.06] dark:border-white/10 overflow-hidden">
                                        <div id="settings-label-list">
                                            {% include 'settings/_labels.html.twig' with {
                                                manageableAccounts: manageableAccounts,
                                                labelsByAccount: labelsByAccount,
                                            } %}
                                        </div>
                                    </div>
                                </section>

                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
