{% if manageableAccounts is empty %}
    <p class="px-4 py-8 text-center text-sm text-ink-faint italic">
        {{ 'settings.accounts.empty'|trans }}
    </p>
{% else %}
    <ul class="divide-y divide-line"
        data-controller="sortable"
        data-sortable-handle-value=".account-drag-handle"
        data-sortable-resource-name-value="account"
        data-sortable-response-kind-value="turbo-stream"
        data-sortable-animation-value="150">
        {% for account in manageableAccounts %}
            {% set isPassword = account.authType == 'password' %}
            <li class="flex items-center gap-3 px-4 py-3.5"
                data-sortable-update-url="{{ path('app_account_reorder', { id: account.id }) }}">

                <button
                    type="button"
                    class="account-drag-handle shrink-0 w-5 h-8 flex items-center justify-center text-ink-faint hover:text-ink-muted cursor-grab active:cursor-grabbing touch-none"
                    aria-label="{{ 'settings.accounts.reorder'|trans }}" title="{{ 'settings.accounts.reorder'|trans }}"
                >
                    <i class="fa-solid fa-grip-vertical text-xs" aria-hidden="true"></i>
                </button>

                <span class="w-2.5 h-2.5 rounded-full shrink-0 {{ account.isActive ? 'bg-green-400' : 'bg-ink-faint' }}"
                      title="{{ account.isActive ? 'settings.accounts.status.active'|trans : 'settings.accounts.status.disabled'|trans }}"></span>

                <div class="min-w-0 flex-1">
                    <p class="flex items-center gap-2 min-w-0">
                        <span class="truncate text-sm font-medium text-ink">{{ account.email ?: account.username }}</span>
                        {% if loop.first %}
                            <span class="shrink-0 inline-flex items-center rounded-full bg-blue-500/10 px-2 py-0.5 text-[11px] font-medium text-accent">
                                {{ 'settings.accounts.primary'|trans }}
                            </span>
                        {% endif %}
                    </p>
                    <p class="truncate text-xs text-ink-faint">{{ account.username }} · {{ account.imapHost }}</p>
                </div>

                <span class="hidden sm:inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium
                             {{ isPassword ? 'bg-zinc-500/10 text-ink-muted' : 'bg-accent-soft text-accent' }}">
                    {{ isPassword ? 'settings.accounts.type.imap'|trans : 'settings.accounts.type.oauth'|trans({ '%provider%': account.oauthProvider|capitalize }) }}
                </span>

                <div class="flex items-center gap-1 shrink-0">
                    {% if isPassword %}
                        <button
                            type="button"
                            data-controller="modal"
                            data-action="click->modal#open"
                            data-modal-title-value="{{ 'settings.accounts.edit'|trans }}"
                            data-modal-src-value="{{ path('app_account_edit', { id: account.id }) }}"
                            class="w-8 h-8 flex items-center justify-center rounded-lg text-zinc-400 hover:text-ink hover:bg-hover transition-colors cursor-pointer"
                            aria-label="{{ 'settings.accounts.edit'|trans }}" title="{{ 'settings.accounts.edit'|trans }}"
                        >
                            <i class="fa-solid fa-pen text-xs" aria-hidden="true"></i>
                        </button>
                    {% endif %}

                    <form method="post" action="{{ path('app_account_toggle', { id: account.id }) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ account.id) }}">
                        <button
                            type="submit"
                            class="w-8 h-8 flex items-center justify-center rounded-lg text-zinc-400 hover:text-ink hover:bg-hover transition-colors cursor-pointer"
                            aria-label="{{ account.isActive ? 'settings.accounts.disable'|trans : 'settings.accounts.enable'|trans }}"
                            title="{{ account.isActive ? 'settings.accounts.disable'|trans : 'settings.accounts.enable'|trans }}"
                        >
                            <i class="fa-solid {{ account.isActive ? 'fa-toggle-on text-green-500' : 'fa-toggle-off' }} text-base" aria-hidden="true"></i>
                        </button>
                    </form>

                    <form method="post" action="{{ path('app_account_delete', { id: account.id }) }}"
                          data-turbo-confirm="{{ 'settings.accounts.delete_confirm'|trans({ '%account%': account.email ?: account.username }) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ account.id) }}">
                        <button
                            type="submit"
                            class="w-8 h-8 flex items-center justify-center rounded-lg text-zinc-400 hover:text-danger hover:bg-red-500/10 transition-colors cursor-pointer"
                            aria-label="{{ 'settings.accounts.delete'|trans }}" title="{{ 'settings.accounts.delete'|trans }}"
                        >
                            <i class="fa-solid fa-trash text-xs" aria-hidden="true"></i>
                        </button>
                    </form>
                </div>
            </li>
        {% endfor %}
    </ul>
{% endif %}
