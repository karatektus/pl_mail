{# Delivery mode toggle. Provider-agnostic: rendered for any account the push
   registry can resolve (Gmail watch, Graph subscription). IMAP accounts have no
   push manager and should not include this partial.

   Expected context: account, health (PushHealth), expiresAt, isConfigured, failed.

   The frame id is account-scoped because the accounts pane lists several. #}

<turbo-frame id="account-push-{{ account.id }}">
    <div class="rounded-xl border border-white/40 dark:border-white/10 bg-white/80 dark:bg-gray-900/80 backdrop-blur-xl p-4">
        <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
                <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100">
                    {{ 'settings.accounts.push.title'|trans }}
                </p>

                <p class="mt-1 text-xs leading-relaxed text-zinc-500 dark:text-zinc-400">
                    {% if account.pushEnabled %}
                        {{ 'settings.accounts.push.on_hint'|trans }}
                        {% if expiresAt %}
                            <span class="block mt-1 text-zinc-400 dark:text-zinc-500">
                                {{ 'settings.accounts.push.renews'|trans({
                                    '%date%': expiresAt|date('j M Y, H:i')
                                }) }}
                            </span>
                        {% endif %}
                    {% else %}
                        {{ 'settings.accounts.push.off_hint'|trans }}
                    {% endif %}
                </p>

                {% if not isConfigured %}
                    <p class="mt-2 flex items-start gap-2 rounded-lg bg-zinc-100/80 dark:bg-zinc-800/60 px-3 py-2 text-xs text-zinc-600 dark:text-zinc-400">
                        <i class="fa-solid fa-circle-info mt-0.5"></i>
                        <span>{{ 'settings.accounts.push.not_configured'|trans }}</span>
                    </p>
                {% endif %}

                {% if failed|default(false) %}
                    <p class="mt-2 flex items-start gap-2 rounded-lg bg-amber-50/80 dark:bg-amber-950/40 px-3 py-2 text-xs text-amber-800 dark:text-amber-300">
                        <i class="fa-solid fa-triangle-exclamation mt-0.5"></i>
                        <span>{{ 'settings.accounts.push.failed'|trans }}</span>
                    </p>
                {% endif %}

                {# Degraded is the Gmail-specific failure the user cannot otherwise
                   see: the watch registered fine, but the Cloud Pub/Sub push
                   subscription never forwards anything. #}
                {% if health.value == 'degraded' and not failed|default(false) %}
                    <div class="mt-2 rounded-lg bg-amber-50/80 dark:bg-amber-950/40 px-3 py-2 text-xs text-amber-800 dark:text-amber-300">
                        <p class="flex items-start gap-2">
                            <i class="fa-solid fa-triangle-exclamation mt-0.5"></i>
                            <span>{{ 'settings.accounts.push.degraded_hint'|trans }}</span>
                        </p>
                        <form method="post"
                              action="{{ path('settings_account_push_repair', {id: account.id}) }}"
                              class="mt-2">
                            <input type="hidden" name="_token" value="{{ csrf_token('account_push_' ~ account.id) }}">
                            <button type="submit"
                                    class="inline-flex items-center gap-1.5 rounded-md bg-amber-100 dark:bg-amber-900/60 px-2.5 py-1 font-medium text-amber-900 dark:text-amber-200 transition-colors hover:bg-amber-200 dark:hover:bg-amber-900">
                                <i class="fa-solid fa-rotate-right"></i>
                                {{ 'settings.accounts.push.reregister'|trans }}
                            </button>
                        </form>
                    </div>
                {% endif %}
            </div>

            <form method="post"
                  action="{{ path('settings_account_push_toggle', {id: account.id}) }}"
                  class="shrink-0">
                <input type="hidden" name="_token" value="{{ csrf_token('account_push_' ~ account.id) }}">

                <button type="submit"
                        role="switch"
                        aria-checked="{{ account.pushEnabled ? 'true' : 'false' }}"
                        aria-label="{{ 'settings.accounts.push.title'|trans }}"
                    {{ not isConfigured and not account.pushEnabled ? 'disabled' : '' }}
                        class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors duration-200
                               focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2
                               disabled:cursor-not-allowed disabled:opacity-40
                               dark:focus-visible:ring-offset-gray-900
                               {{ account.pushEnabled ? 'bg-indigo-600' : 'bg-zinc-300 dark:bg-zinc-700' }}">
                    <span class="inline-block h-4 w-4 transform rounded-full bg-white shadow transition-transform duration-200
                                 {{ account.pushEnabled ? 'translate-x-6' : 'translate-x-1' }}"></span>
                </button>
            </form>
        </div>

        <div class="mt-3 flex items-center gap-2 text-xs">
            <span class="inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 font-medium {{ health.badgeClasses }}">
                <i class="fa-solid {{ health.icon }}"></i>
                {{ health.translationKey|trans }}
            </span>
        </div>
    </div>
</turbo-frame>
