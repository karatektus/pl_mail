{# templates/compose/_window.html.twig #}
{% form_theme form '_layout/form/compose_theme.html.twig' %}

<turbo-frame id="compose_dock">
    <div data-controller="compose"
         data-compose-draft-url-value="{{ path('app_compose_draft') }}"
         class="w-[520px] rounded-2xl shadow-2xl shadow-black/20 dark:shadow-black/60
                bg-white/80 dark:bg-gray-900/80
                backdrop-blur-xl
                border border-white/60 dark:border-white/10
                flex flex-col overflow-hidden mb-4">

        {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

        {# ── Header ───────────────────────────────────────────────── #}
        <div class="flex items-center justify-between px-4 py-2.5
                    bg-gray-800 dark:bg-gray-950
                    rounded-t-2xl select-none shrink-0"
             data-action="dblclick->compose#toggleMinimize">
            <span class="text-sm font-semibold text-white cursor-pointer"
                  data-action="click->compose#toggleMinimize">New Message</span>
            <div class="flex items-center gap-1">
                <span data-compose-target="saveStatus"
                      class="text-xs text-gray-400 mr-2 transition-colors"></span>
                <button type="button" title="Minimize"
                        data-action="click->compose#toggleMinimize"
                        class="w-7 h-7 flex items-center justify-center rounded-lg
                               text-gray-400 hover:text-white hover:bg-white/10 transition-colors">
                    <i data-compose-target="minimizeIcon" class="fa-solid fa-minus text-xs"></i>
                </button>
                <button type="button" title="Expand"
                        data-action="click->compose#toggleExpand"
                        class="w-7 h-7 flex items-center justify-center rounded-lg
                               text-gray-400 hover:text-white hover:bg-white/10 transition-colors">
                    <i data-compose-target="expandIcon"
                       class="fa-solid fa-up-right-and-down-left-from-center text-[10px]"></i>
                </button>
                <button type="button" title="Save draft and close"
                        data-action="compose#saveDraft compose#close"
                        class="w-7 h-7 flex items-center justify-center rounded-lg
                               text-gray-400 hover:text-white hover:bg-white/10 transition-colors">
                    <i class="fa-solid fa-xmark text-sm"></i>
                </button>
            </div>
        </div>

        {# ── Collapsible body ─────────────────────────────────────── #}
        <div data-compose-target="collapsible" class="flex flex-col flex-1 min-h-0">

            {# ── From ─────────────────────────────────────────────────── #}
            <div class="flex items-center gap-3 px-4 border-b border-gray-100 dark:border-gray-800 min-h-[38px]">
                <span class="text-xs font-medium text-gray-400 dark:text-gray-500 w-8 shrink-0">From</span>
                <select id="{{ form.account.vars.id }}"
                        name="{{ form.account.vars.full_name }}"
                        class="flex-1 bg-transparent outline-none text-sm
                           text-gray-700 dark:text-gray-300 cursor-pointer py-1">
                    {% for choice in form.account.vars.choices %}
                        <option value="{{ choice.value }}"
                                {% if form.account.vars.value == choice.value %}selected{% endif %}>
                            {{ choice.label }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            {# ── To ───────────────────────────────────────────────────── #}
            <div class="flex items-center gap-3 px-4 border-b border-gray-100 dark:border-gray-800 min-h-[38px]">
                <span class="text-xs font-medium text-gray-400 dark:text-gray-500 w-8 shrink-0">To</span>
                <div class="flex-1 py-1 compose-collection compose-to"
                     id="{{ form.toAddresses.vars.id }}"
                     data-prototype="{{ form_widget(form.toAddresses.vars.prototype)|e('html_attr') }}"
                     data-index="{{ form.toAddresses|length }}">
                    {% for entry in form.toAddresses %}
                        {{ form_widget(entry) }}
                    {% endfor %}
                </div>
                <div class="flex gap-2 text-xs font-medium shrink-0">
                <span class="cursor-pointer text-gray-400 dark:text-gray-500 hover:text-blue-500 transition-colors"
                      data-action="click->compose#showCc">Cc</span>
                    <span class="cursor-pointer text-gray-400 dark:text-gray-500 hover:text-blue-500 transition-colors"
                          data-action="click->compose#showBcc">Bcc</span>
                </div>
            </div>

            {# ── Cc ───────────────────────────────────────────────────── #}
            <div data-compose-target="ccField"
                 class="hidden items-center gap-3 px-4 border-b border-gray-100 dark:border-gray-800 min-h-[38px]">
                <span class="text-xs font-medium text-gray-400 dark:text-gray-500 w-8 shrink-0">Cc</span>
                <div class="flex-1 py-1 compose-collection compose-cc"
                     id="{{ form.ccAddresses.vars.id }}"
                     data-prototype="{{ form_widget(form.ccAddresses.vars.prototype)|e('html_attr') }}"
                     data-index="{{ form.ccAddresses|length }}">
                    {% for entry in form.ccAddresses %}
                        {{ form_widget(entry) }}
                    {% endfor %}
                </div>
            </div>

            {# ── Bcc ──────────────────────────────────────────────────── #}
            <div data-compose-target="bccField"
                 class="hidden items-center gap-3 px-4 border-b border-gray-100 dark:border-gray-800 min-h-[38px]">
                <span class="text-xs font-medium text-gray-400 dark:text-gray-500 w-8 shrink-0">Bcc</span>
                <div class="flex-1 py-1 compose-collection compose-bcc"
                     id="{{ form.bccAddresses.vars.id }}"
                     data-prototype="{{ form_widget(form.bccAddresses.vars.prototype)|e('html_attr') }}"
                     data-index="{{ form.bccAddresses|length }}">
                    {% for entry in form.bccAddresses %}
                        {{ form_widget(entry) }}
                    {% endfor %}
                </div>
            </div>

            {# ── Subject ──────────────────────────────────────────────── #}
            <div class="flex items-center gap-3 px-4 border-b border-gray-100 dark:border-gray-800 min-h-[38px]">
                <input type="text"
                       id="{{ form.subject.vars.id }}"
                       name="{{ form.subject.vars.full_name }}"
                       value="{{ form.subject.vars.value ?: '' }}"
                       placeholder="Subject"
                       class="flex-1 bg-transparent outline-none text-sm font-medium py-1
                          text-gray-800 dark:text-gray-100
                          placeholder-gray-400 dark:placeholder-gray-600"/>
            </div>

            {# ── Body ─────────────────────────────────────────────────── #}
            <div class="flex-1 flex flex-col min-h-[200px] px-4 py-3">
            <textarea id="{{ form.bodyHtml.vars.id }}"
                      name="{{ form.bodyHtml.vars.full_name }}"
                      data-compose-target="body"
                      placeholder="Write your message…"
                      class="flex-1 w-full min-h-[190px] bg-transparent outline-none resize-none
                             text-sm leading-relaxed
                             text-gray-800 dark:text-gray-100
                             placeholder-gray-400 dark:placeholder-gray-600">{{ form.bodyHtml.vars.value ?: '' }}</textarea>
            </div>

            {# ── Toolbar ──────────────────────────────────────────────── #}
            <div class="px-3 pb-3 pt-1 border-t border-gray-100 dark:border-gray-800 shrink-0">

                {# Formatting bubble #}
                <div class="flex items-center gap-0.5 mb-2 flex-wrap
                        bg-gray-100/80 dark:bg-gray-800/60
                        rounded-full px-2 py-1">
                    <select class="bg-transparent border-none outline-none text-xs cursor-pointer px-1 py-0.5 rounded
                               text-gray-600 dark:text-gray-400
                               hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
                        <option>Sans Serif</option>
                        <option>Serif</option>
                        <option>Monospace</option>
                    </select>
                    <div class="w-px h-4 bg-gray-300 dark:bg-gray-600 mx-1 shrink-0"></div>
                    <button type="button" class="flex items-center gap-0.5 px-1.5 py-0.5 rounded transition-colors
                                             text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700">
                        <span class="text-base font-bold leading-none">T</span><span class="text-[10px] font-bold leading-none">T</span>
                        <i class="fa-solid fa-chevron-down text-[8px] ml-0.5"></i>
                    </button>
                    <div class="w-px h-4 bg-gray-300 dark:bg-gray-600 mx-1 shrink-0"></div>
                    <button type="button" class="px-1.5 py-0.5 rounded font-bold text-sm transition-colors
                                             text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700">B</button>
                    <button type="button" class="px-1.5 py-0.5 rounded italic text-sm transition-colors
                                             text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700">I</button>
                    <button type="button" class="px-1.5 py-0.5 rounded underline text-sm transition-colors
                                             text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700">U</button>
                    <button type="button" class="px-1.5 py-0.5 rounded text-sm flex flex-col items-center leading-none gap-0.5 transition-colors
                                             text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700">
                        <span class="font-semibold">A</span>
                        <span class="block w-3.5 h-[3px] bg-blue-500 rounded-sm"></span>
                    </button>
                    <div class="w-px h-4 bg-gray-300 dark:bg-gray-600 mx-1 shrink-0"></div>
                    <button type="button" class="flex items-center gap-0.5 px-1.5 py-0.5 rounded text-sm transition-colors
                                             text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700">
                        <i class="fa-solid fa-align-left"></i><i class="fa-solid fa-chevron-down text-[8px]"></i>
                    </button>
                    <button type="button" class="px-1.5 py-0.5 rounded text-sm transition-colors text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700"><i class="fa-solid fa-list-ol"></i></button>
                    <button type="button" class="px-1.5 py-0.5 rounded text-sm transition-colors text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700"><i class="fa-solid fa-list-ul"></i></button>
                    <button type="button" class="px-1.5 py-0.5 rounded text-sm transition-colors text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700"><i class="fa-solid fa-outdent"></i></button>
                    <button type="button" class="px-1.5 py-0.5 rounded text-sm transition-colors text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700"><i class="fa-solid fa-indent"></i></button>
                    <div class="w-px h-4 bg-gray-300 dark:bg-gray-600 mx-1 shrink-0"></div>
                    <button type="button" class="px-1.5 py-0.5 rounded text-sm transition-colors text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700"><i class="fa-solid fa-ellipsis-vertical"></i></button>
                </div>

                {# Action bar #}
                <div class="flex items-center gap-1">
                    <div class="flex items-center rounded-full overflow-hidden bg-blue-600 mr-2 shrink-0">
                        <button type="submit"
                                class="text-white text-sm font-semibold px-4 py-1.5 hover:bg-white/10 transition-colors">
                            Send
                        </button>
                        <button type="button"
                                class="text-white border-l border-white/30 px-2.5 py-1.5 hover:bg-white/10 transition-colors text-xs">
                            <i class="fa-solid fa-chevron-down"></i>
                        </button>
                    </div>

                    {% set ic = "w-8 h-8 flex items-center justify-center rounded-full transition-colors text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800" %}
                    <button type="button" class="{{ ic }} text-sm font-bold tracking-tighter">Aa</button>
                    <button type="button" class="{{ ic }}"><i class="fa-solid fa-paperclip"></i></button>
                    <button type="button" class="{{ ic }}"><i class="fa-solid fa-link"></i></button>
                    <button type="button" class="{{ ic }}"><i class="fa-regular fa-face-smile"></i></button>
                    <button type="button" class="{{ ic }}"><i class="fa-brands fa-google-drive"></i></button>
                    <button type="button" class="{{ ic }}"><i class="fa-regular fa-image"></i></button>
                    <button type="button" class="{{ ic }}"><i class="fa-solid fa-lock"></i></button>
                    <button type="button" class="{{ ic }}"><i class="fa-solid fa-pen-nib"></i></button>
                    <button type="button" class="{{ ic }}"><i class="fa-solid fa-ellipsis-vertical"></i></button>

                    <div class="flex-1"></div>

                    <button type="button"
                            data-action="compose#close"
                            title="Discard draft"
                            class="{{ ic }} hover:text-red-500 dark:hover:text-red-400">
                        <i class="fa-regular fa-trash-can"></i>
                    </button>
                </div>
            </div>

        </div>{# end collapsible #}

        <input type="hidden" name="compose[_token]" value="{{ csrf_token('compose') }}">
        {{ form_end(form, { render_rest: false }) }}

    </div>
</turbo-frame>
