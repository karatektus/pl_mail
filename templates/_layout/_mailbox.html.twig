{% extends '_layout/app.html.twig' %}

{% set selectedMessage = selectedMessage|default(null) %}

{#
Subclasses can override these blocks:
  inbox_tabs      — tabs / heading row above the toolbar (renders before toolbar)
  inbox_toolbar   — override the entire toolbar (rarely needed)
  message_list    — the <li> items inside the <ul>
  reading_pane    — the reading pane content
  pane_open       — "true"/"false" string (default false)
  list_hidden     — extra CSS classes to hide list on direct-load pages
  reading_hidden  — extra CSS classes (default: "hidden")

Pagination variables expected from the controller (all optional, fallback to 0/1):
  page, total, per_page
#}

{% block body %}
    {#
    sidebar-drawer wraps the entire page so the controller can manage
    the drawer state from any trigger (burger button in the topbar, backdrop).
    #}
    <div
        class="h-screen overflow-hidden app-bg"
        data-controller="sidebar-drawer"
    >
        {# ── Mobile backdrop ──────────────────────────────────────────────── #}
        <div
            data-sidebar-drawer-target="backdrop"
            data-action="click->sidebar-drawer#backdropClick"
            class="md:hidden fixed inset-0 z-30 bg-black/40 backdrop-blur-sm
                   opacity-0 pointer-events-none transition-opacity duration-200"
            aria-hidden="true"
        ></div>

        {# ── Mobile sidebar drawer ────────────────────────────────────────── #}
        {#
        On mobile: fixed, full-height, slides in from the left.
        On md+: hidden (the normal sidebar is in the flex row below).
        #}
        <div
            data-sidebar-drawer-target="drawer"
            class="md:hidden fixed inset-y-0 left-0 z-40 w-64 p-3
                   -translate-x-full transition-transform duration-200 ease-out"
            aria-label="{{ 'sidebar.nav.inbox'|trans }}"
        >
            {% include '_partials/_sidebar.html.twig' with { _drawerMode: true } %}
        </div>

        <div class="flex h-full flex-col p-3 gap-3">

            {# Full-width topbar — passes burger button context #}
            {% include '_partials/_topbar.html.twig' with { _showBurger: true } %}

            {# Sidebar + content #}
            <div class="flex flex-1 gap-3 overflow-hidden">

                {# Sidebar — desktop only (hidden on mobile, shown in drawer) #}
                <div class="hidden md:flex">
                    {% include '_partials/_sidebar.html.twig' %}
                </div>

                {# Main content #}
                <div class="flex flex-1 overflow-hidden relative pane">

                    {# List pane #}
                    <div
                        id="message-list"
                        data-mailbox-id="{{ mailbox is defined ? [mailbox.id]|json_encode : mailboxIds is defined ? mailboxIds|json_encode : []|json_encode }}"
                        data-mail-pane-target="list"
                        class="flex flex-col flex-1 overflow-hidden {% block list_hidden %}{% endblock %}"
                    >
                        <turbo-frame id="inbox-list-frame" data-turbo-action="advance" class="contents">

                            {# ── Gmail-style toolbar ──────────────────────── #}
                            {% block inbox_toolbar %}
                                {% include '_partials/_list_toolbar.html.twig' with {
                                    page:     page     ?? 1,
                                    total:    total    ?? 0,
                                    per_page: per_page ?? 50,
                                } %}
                            {% endblock %}

                            {# Optional tabs row (inbox only) #}
                            {% block inbox_tabs %}{% endblock %}

                            <ul class="flex-1 overflow-y-auto divide-y divide-gray-100/70 dark:divide-gray-800/70">
                                {% block message_list %}{% endblock %}
                            </ul>

                        </turbo-frame>
                    </div>

                    {# Reading pane #}
                    <div
                        data-mail-pane-target="reading"
                        class="flex flex-col flex-1 overflow-hidden {% block reading_hidden %}hidden{% endblock %}"
                    >
                        {% block reading_pane %}
                            {% if selectedMessage is not null %}
                                {% include 'mail/_message_content.html.twig' with { message: selectedMessage } %}
                            {% endif %}
                        {% endblock %}
                    </div>

                </div>
            </div>
        </div>
    </div>
{% endblock %}
