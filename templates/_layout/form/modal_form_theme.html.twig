{# ── Row wrapper ─────────────────────────────────────────────────────────── #}
{% block form_row %}
    <div class="flex flex-col gap-1.5">
        {{ form_label(form) }}
        {{ form_widget(form) }}
        {{ form_errors(form) }}
        {{ form_help(form) }}
    </div>
{% endblock %}

{# ── Label ───────────────────────────────────────────────────────────────── #}
{% block form_label %}
    {% if label is not same as(false) %}
        {% set label = label ?? (name|humanize) %}
        <label
            for="{{ id }}"
            class="block text-[13px] font-medium leading-none text-zinc-700 dark:text-zinc-300"
            {% if required %}{% endif %}
        >
            {{ label|trans({}, translation_domain) }}
            {% if required %}
                <span class="ml-0.5 text-red-500 dark:text-red-400" aria-hidden="true">*</span>
            {% endif %}
        </label>
    {% endif %}
{% endblock %}

{# ── Text / email / password / number / url / search inputs ─────────────── #}
{% block text_widget %}
    {% set attr = attr|merge({
        class: 'block w-full h-9 rounded-lg border border-zinc-300/40 dark:border-zinc-600/30
            bg-white/60 dark:bg-zinc-800/40
            px-3 text-sm text-zinc-900 dark:text-zinc-300
            placeholder:text-zinc-400 dark:placeholder:text-zinc-500
            shadow-sm shadow-zinc-950/5
            focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent
            transition-colors duration-100
            disabled:opacity-50 disabled:cursor-not-allowed
            ' ~ (attr.class ?? '')
    }) %}
    {{ block('form_widget_simple') }}
{% endblock %}

{% block email_widget    %}{% set type = 'email'    %}{{ block('text_widget') }}{% endblock %}
{% block password_widget %}{% set type = 'password' %}{{ block('text_widget') }}{% endblock %}
{% block url_widget      %}{% set type = 'url'      %}{{ block('text_widget') }}{% endblock %}
{% block search_widget   %}{% set type = 'search'   %}{{ block('text_widget') }}{% endblock %}
{% block tel_widget      %}{% set type = 'tel'      %}{{ block('text_widget') }}{% endblock %}

{# ── Number ──────────────────────────────────────────────────────────────── #}
{% block number_widget %}
    {% set attr = attr|merge({
        class: 'block w-full h-9 rounded-lg border border-zinc-300/40 dark:border-zinc-600/30
            bg-white/60 dark:bg-zinc-800/40
            px-3 text-sm text-zinc-900 dark:text-zinc-100
            placeholder:text-zinc-400 dark:placeholder:text-zinc-500
            shadow-sm shadow-zinc-950/5
            focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent
            transition-colors duration-100
            disabled:opacity-50 disabled:cursor-not-allowed
            [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none
            ' ~ (attr.class ?? '')
    }) %}
    <input type="number" {{ block('widget_attributes') }} value="{{ value != '' ? value }}">
{% endblock %}

{% block integer_widget %}{{ block('number_widget') }}{% endblock %}

{# ── Textarea ────────────────────────────────────────────────────────────── #}
{% block textarea_widget %}
    {% set attr = attr|merge({
        class: 'block w-full rounded-lg border border-zinc-300/40 dark:border-zinc-600/30
            bg-white/60 dark:bg-zinc-800/40
            px-3 py-2 text-sm text-zinc-900 dark:text-zinc-100
            placeholder:text-zinc-400 dark:placeholder:text-zinc-500
            shadow-sm shadow-zinc-950/5
            focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent
            resize-y transition-colors duration-100
            disabled:opacity-50 disabled:cursor-not-allowed
            ' ~ (attr.class ?? ''),
        rows: attr.rows ?? 3,
    }) %}
    <textarea {{ block('widget_attributes') }}>{{ value }}</textarea>
{% endblock %}

{# ── Select ──────────────────────────────────────────────────────────────── #}
{% block choice_widget_collapsed %}
    {% set attr = attr|merge({
        class: 'block w-full h-9 rounded-lg border border-zinc-300/40 dark:border-zinc-600/30
            bg-white/60 dark:bg-zinc-800/40
            pl-3 pr-8 text-sm text-zinc-900 dark:text-zinc-100
            shadow-sm shadow-zinc-950/5 appearance-none
            focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent
            transition-colors duration-100
            cursor-pointer
            disabled:opacity-50 disabled:cursor-not-allowed
            ' ~ (attr.class ?? '')
    }) %}
    <div class="relative">
        <select {{ block('widget_attributes') }}>
            {% if placeholder is not none %}
                <option value=""{% if not value %} selected{% endif %} disabled>{{ placeholder|trans({}, translation_domain) }}</option>
            {% endif %}
            {% if preferred_choices|length > 0 %}
                {% set options = preferred_choices %}
                {{ block('choice_widget_options') }}
                {% if choices|length > 0 and separator is not none %}
                    <option disabled>{{ separator }}</option>
                {% endif %}
            {% endif %}
            {% set options = choices %}
            {{ block('choice_widget_options') }}
        </select>
        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2.5 text-zinc-400 dark:text-zinc-500">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="size-3.5" aria-hidden="true">
                <path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
            </svg>
        </div>
    </div>
{% endblock %}

{# ── Checkbox ────────────────────────────────────────────────────────────── #}
{% block checkbox_widget %}
    {% set attr = attr|merge({
        class: 'size-4 rounded border-zinc-300 dark:border-zinc-600
            text-blue-600 dark:text-blue-500
            bg-white dark:bg-zinc-800
            focus:ring-2 focus:ring-blue-500 focus:ring-offset-0
            cursor-pointer
            ' ~ (attr.class ?? '')
    }) %}
    {{ block('form_widget_simple') }}
{% endblock %}

{% block checkbox_row %}
    <div class="flex items-center gap-2.5">
        {{ form_widget(form) }}
        <label for="{{ id }}" class="text-sm text-zinc-700 dark:text-zinc-300 cursor-pointer leading-none">
            {{ label ?? (name|humanize)|trans({}, translation_domain) }}
        </label>
    </div>
    {{ form_errors(form) }}
    {{ form_help(form) }}
{% endblock %}

{# ── Field-level errors ──────────────────────────────────────────────────── #}
{% block form_errors %}
    {% if errors|length > 0 %}
        <ul class="space-y-0.5">
            {% for error in errors %}
                <li class="flex items-center gap-1.5 text-[12px] text-red-600 dark:text-red-400 leading-snug">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" fill="currentColor" class="size-3 shrink-0" aria-hidden="true">
                        <path fill-rule="evenodd" d="M6 1a5 5 0 1 0 0 10A5 5 0 0 0 6 1Zm-.75 2.75a.75.75 0 0 1 1.5 0v2.5a.75.75 0 0 1-1.5 0v-2.5Zm.75 5a.75.75 0 1 0 0-1 .75.75 0 0 0 0 1Z" clip-rule="evenodd"/>
                    </svg>
                    {{ error.message }}
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}

{# ── Help text ───────────────────────────────────────────────────────────── #}
{% block form_help %}
    {% if help is not empty %}
        <p class="text-[12px] text-zinc-500 dark:text-zinc-400 leading-snug">
            {{ help|trans({}, translation_domain) }}
        </p>
    {% endif %}
{% endblock %}
