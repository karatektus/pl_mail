{# templates/form/compose_theme.html.twig #}

{#
address_entry_widget / address_entry_row are no longer used —
the compose window uses ts-address fields directly.
Kept here as no-ops so Symfony doesn't throw if they're referenced.
#}
{% block address_entry_widget %}{% endblock %}
{% block address_entry_row %}{% endblock %}

{% block email_widget %}
    <input
        type="text"
        autocomplete="off"
        autocapitalize="off"
        autocorrect="off"
        spellcheck="false"
        {{ block('widget_attributes') }}
        {% if value is not empty %}value="{{ value }}"{% endif %}
        placeholder=""
        class="flex-1 bg-transparent outline-none text-sm
               text-gray-800 dark:text-gray-100
               placeholder-gray-400 dark:placeholder-gray-500
               min-w-0"
    />
{% endblock %}

{% block text_widget %}
    <input
        type="text"
        autocomplete="off"
        autocapitalize="off"
        autocorrect="off"
        spellcheck="false"
        {{ block('widget_attributes') }}
        {% if value is not empty %}value="{{ value }}"{% endif %}
        placeholder=""
        class="flex-1 bg-transparent outline-none text-sm
               text-gray-800 dark:text-gray-100
               placeholder-gray-400 dark:placeholder-gray-500
               min-w-0"
    />
{% endblock %}
