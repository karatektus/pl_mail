{#
label/_form.html.twig — rendered inside the modal frame (same flow as the
account form). Frosted-glass design language, zinc form fields, Tailwind only.
#}
{{ form_start(form, { attr: { class: 'space-y-4' } }) }}

    <div>
        {{ form_label(form.name, null, { label_attr: { class: 'block text-xs font-medium text-ink-muted mb-1' } }) }}
        {{ form_widget(form.name, { attr: {
            class: 'w-full rounded-lg bg-sunken border border-transparent
                    focus:border-accent focus:ring-0 text-sm px-3 py-2
                    text-ink placeholder-gray-400'
        } }) }}
        {{ form_errors(form.name) }}
    </div>

    <div>
        {{ form_label(form.account, null, { label_attr: { class: 'block text-xs font-medium text-ink-muted mb-1' } }) }}
        {{ form_widget(form.account, { attr: {
            class: 'w-full rounded-lg bg-sunken border border-transparent
                    focus:border-accent focus:ring-0 text-sm px-3 py-2
                    text-ink'
        } }) }}
        {{ form_errors(form.account) }}
    </div>

    <div>
        {{ form_label(form.parent, null, { label_attr: { class: 'block text-xs font-medium text-ink-muted mb-1' } }) }}
        {{ form_widget(form.parent, { attr: {
            class: 'w-full rounded-lg bg-sunken border border-transparent
                    focus:border-accent focus:ring-0 text-sm px-3 py-2
                    text-ink'
        } }) }}
        {{ form_errors(form.parent) }}
    </div>

    <div>
        {{ form_label(form.color, null, { label_attr: { class: 'block text-xs font-medium text-ink-muted mb-1' } }) }}
        {{ form_widget(form.color, { attr: {
            class: 'w-full rounded-lg bg-sunken border border-transparent
                    focus:border-accent focus:ring-0 text-sm px-3 py-2
                    text-ink'
        } }) }}
        {{ form_errors(form.color) }}
    </div>

    <div class="flex items-center justify-between gap-3 pt-2">
        {% if label.id is not null %}
            <form method="post" action="{{ path('app_label_delete', { id: label.id }) }}">
                <button type="submit"
                        class="text-sm text-danger hover:underline cursor-pointer">
                    {{ 'label.form.delete'|trans }}
                </button>
            </form>
        {% else %}
            <span></span>
        {% endif %}

        <button type="submit"
                class="bg-accent hover:bg-accent-strong text-white text-sm font-medium
                       rounded-lg px-4 py-2 transition-colors cursor-pointer">
            {{ 'form.submit'|trans }}
        </button>
    </div>

{{ form_end(form) }}
