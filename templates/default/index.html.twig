{% extends '_layout/app.html.twig' %}

{% block title %}Inbox — Mail{% endblock %}

{% block body %}
    <div class="flex flex-col h-screen overflow-hidden bg-gray-50 dark:bg-gray-950">

        {# ===== TOP BAR ===== #}
        <header class="flex items-center gap-4 px-4 h-14 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 flex-shrink-0">

            {# Logo #}
            <div class="flex items-center gap-2 w-52 flex-shrink-0">
                <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                </svg>
                <span class="font-semibold text-gray-800 dark:text-gray-100 text-sm tracking-wide">Mail</span>
            </div>

            {# Search bar #}
            <div class="flex-1 max-w-2xl mx-auto">
                <div class="relative">
                    <svg class="absolute left-3 top-2.5 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                    <input
                        type="text"
                        placeholder="Search mail…"
                        class="w-full pl-10 pr-4 py-2 text-sm bg-gray-100 dark:bg-gray-800 border border-transparent rounded-xl text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white dark:focus:bg-gray-700 transition-colors"
                    >
                </div>
            </div>

            {# Right side actions #}
            <div class="flex items-center gap-1 flex-shrink-0">

                {# Dark mode toggle #}
                <button id="theme-toggle" class="p-2 cursor-pointer rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500 dark:text-gray-400 transition-colors" title="Toggle dark mode">
                    <svg id="icon-moon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                    </svg>
                    <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
                    </svg>
                </button>

                {# User avatar #}
                <div class="relative ml-1">
                    <button id="user-menu-btn" class="flex cursor-pointer items-center justify-center w-8 h-8 rounded-full bg-blue-600 hover:ring-2 hover:ring-blue-400 hover:ring-offset-1 dark:hover:ring-offset-gray-900 text-white text-xs font-semibold transition-all" title="{{ app.user.email }}">
                        {{ app.user.email | first | upper }}
                    </button>

                    {# Dropdown #}
                    <div id="user-menu" class="hidden absolute right-0 mt-2 w-56 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl shadow-lg py-1 z-50">
                        <div class="px-4 py-2.5 border-b border-gray-100 dark:border-gray-800">
                            <p class="text-xs text-gray-400">Signed in as</p>
                            <p class="text-sm font-medium text-gray-900 dark:text-gray-100 truncate">{{ app.user.email }}</p>
                        </div>
                        <a href="#" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800">
                            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            Settings
                        </a>
                        <a href="{{ path('app_logout') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800">
                            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                            </svg>
                            Sign out
                        </a>
                    </div>
                </div>

            </div>
        </header>

        {# ===== MAIN AREA (sidebar + list + reading pane) ===== #}
        <div class="flex flex-1 overflow-hidden">

            {# SIDEBAR #}
            <aside class="flex flex-col w-56 flex-shrink-0 bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800">
                {# Compose button #}
                <div class="px-3 py-3">
                    <button class="w-full flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg px-3 py-2 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                        Compose
                    </button>
                </div>

                {# Folder list #}
                <nav class="flex-1 overflow-y-auto px-2 pb-4 space-y-0.5 text-sm">
                    <a href="#" class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg bg-blue-50 text-blue-700 font-medium">
                <span class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V7a2 2 0 00-2-2H6a2 2 0 00-2 2v6m16 0l-8 5-8-5m16 0v4a2 2 0 01-2 2H6a2 2 0 01-2-2v-4"/>
                    </svg>
                    Inbox
                </span>
                        <span class="bg-blue-600 text-white text-xs font-semibold px-1.5 py-0.5 rounded-full">4</span>
                    </a>
                    <a href="#" class="flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600  dark:text-gray-400 hover:bg-gray-100  dark:hover:bg-gray-800">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                        </svg>
                        Starred
                    </a>
                    <a href="#" class="flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600  dark:text-gray-400 hover:bg-gray-100  dark:hover:bg-gray-800">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Snoozed
                    </a>
                    <a href="#" class="flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600  dark:text-gray-400 hover:bg-gray-100  dark:hover:bg-gray-800">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                        </svg>
                        Sent
                    </a>
                    <a href="#" class="flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600  dark:text-gray-400 hover:bg-gray-100  dark:hover:bg-gray-800">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        Drafts
                    </a>
                    <a href="#" class="flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600  dark:text-gray-400 hover:bg-gray-100  dark:hover:bg-gray-800">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                        Trash
                    </a>

                    <div class="pt-3 pb-1 px-3">
                        <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Accounts</span>
                    </div>
                    <a href="#" class="flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600  dark:text-gray-400 hover:bg-gray-100  dark:hover:bg-gray-800">
                        <span class="w-2 h-2 rounded-full bg-green-400 flex-shrink-0"></span>
                        user@example.com
                    </a>
                </nav>
            </aside>

            {# ===== MESSAGE LIST ===== #}
            <div class="flex flex-col w-80 flex-shrink-0 bg-white dark:bg-gray-900 border-r border-gray-200  dark:border-gray-800">

                {# Tabs #}
                <div class="border-b border-gray-200  dark:border-gray-800 px-1">
                    <nav class="flex text-sm" aria-label="Inbox tabs">
                        <button class="px-4 py-3 font-medium text-blue-600 border-b-2 border-blue-600 -mb-px">Primary</button>
                        <button class="px-4 py-3 text-gray-500 hover:text-gray-700 border-b-2 border-transparent hover:border-gray-300 -mb-px">Promotions</button>
                        <button class="px-4 py-3 text-gray-500 hover:text-gray-700 border-b-2 border-transparent hover:border-gray-300 -mb-px">Updates</button>
                        <button class="px-4 py-3 text-gray-500 hover:text-gray-700 border-b-2 border-transparent hover:border-gray-300 -mb-px">Social</button>
                    </nav>
                </div>

                {# Search #}
                <div class="px-3 py-2 border-b border-gray-100">
                    <div class="relative">
                        <svg class="absolute left-2.5 top-2.5 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                        <input type="text" placeholder="Search mail…" class="w-full pl-8 pr-3 py-1.5 text-sm bg-gray-100  dark:bg-gray-800 border border-transparent rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white dark:bg-gray-900">
                    </div>
                </div>

                {# Message rows #}
                <ul class="flex-1 overflow-y-auto divide-y divide-gray-100">

                    {# Unread message #}
                    <li class="flex gap-3 px-3 py-3 hover:bg-gray-50  dark:bg-gray-950 cursor-pointer bg-blue-50/40  dark:bg-blue-950/30 border-l-2 border-blue-500">
                        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-purple-500 text-white text-xs font-semibold flex items-center justify-center">JD</div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-baseline justify-between gap-1">
                                <span class="text-sm font-semibold text-gray-900  dark:text-gray-100 truncate">Jane Doe</span>
                                <span class="text-xs text-gray-400 flex-shrink-0">10:42</span>
                            </div>
                            <p class="text-xs font-medium text-gray-800 truncate">Project kickoff tomorrow</p>
                            <p class="text-xs text-gray-400 truncate">Just confirming we're still on for 9am…</p>
                        </div>
                    </li>

                    {# Unread message #}
                    <li class="flex gap-3 px-3 py-3 hover:bg-gray-50  dark:bg-gray-950 cursor-pointer bg-blue-50/40  dark:bg-blue-950/30 border-l-2 border-blue-500">
                        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-orange-400 text-white text-xs font-semibold flex items-center justify-center">TK</div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-baseline justify-between gap-1">
                                <span class="text-sm font-semibold text-gray-900  dark:text-gray-100 truncate">Tom K.</span>
                                <span class="text-xs text-gray-400 flex-shrink-0">09:15</span>
                            </div>
                            <p class="text-xs font-medium text-gray-800 truncate">Invoice #1042 attached</p>
                            <p class="text-xs text-gray-400 truncate">Please find the invoice for last month…</p>
                        </div>
                    </li>

                    {# Read message #}
                    <li class="flex gap-3 px-3 py-3 hover:bg-gray-50  dark:bg-gray-950 cursor-pointer">
                        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-gray-300 text-gray-600  dark:text-gray-400 text-xs font-semibold flex items-center justify-center">AL</div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-baseline justify-between gap-1">
                                <span class="text-sm text-gray-600  dark:text-gray-400 truncate">Anna L.</span>
                                <span class="text-xs text-gray-400 flex-shrink-0">Yesterday</span>
                            </div>
                            <p class="text-xs text-gray-600  dark:text-gray-400 truncate">Re: Design feedback</p>
                            <p class="text-xs text-gray-400 truncate">Thanks for the notes, I'll update the mockups…</p>
                        </div>
                    </li>

                    {# Read message #}
                    <li class="flex gap-3 px-3 py-3 hover:bg-gray-50  dark:bg-gray-950 cursor-pointer">
                        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-gray-300 text-gray-600  dark:text-gray-400 text-xs font-semibold flex items-center justify-center">GH</div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-baseline justify-between gap-1">
                                <span class="text-sm text-gray-600  dark:text-gray-400 truncate">GitHub</span>
                                <span class="text-xs text-gray-400 flex-shrink-0">Mon</span>
                            </div>
                            <p class="text-xs text-gray-600  dark:text-gray-400 truncate">[mail-client] PR #3 opened</p>
                            <p class="text-xs text-gray-400 truncate">someone opened a pull request in your repo…</p>
                        </div>
                    </li>

                </ul>
            </div>

            {# ===== READING PANE ===== #}
            <main class="flex-1 flex flex-col overflow-hidden">

                {# Reading pane toolbar #}
                <div class="flex items-center gap-2 px-4 h-14 border-b border-gray-200  dark:border-gray-800 bg-white dark:bg-gray-900 flex-shrink-0">
                    <button class="p-1.5 rounded hover:bg-gray-100  dark:hover:bg-gray-800 text-gray-500" title="Archive">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
                        </svg>
                    </button>
                    <button class="p-1.5 rounded hover:bg-gray-100  dark:hover:bg-gray-800 text-gray-500" title="Delete">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                    </button>
                    <button class="p-1.5 rounded hover:bg-gray-100  dark:hover:bg-gray-800 text-gray-500" title="Mark unread">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                    </button>
                </div>

                {# Message content #}
                <div class="flex-1 overflow-y-auto p-6 max-w-3xl w-full">
                    <h1 class="text-xl font-semibold text-gray-900  dark:text-gray-100 mb-3">Project kickoff tomorrow</h1>

                    <div class="flex items-start justify-between mb-6">
                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 rounded-full bg-purple-500 text-white text-sm font-semibold flex items-center justify-center flex-shrink-0">JD</div>
                            <div>
                                <p class="text-sm font-medium text-gray-900  dark:text-gray-100">Jane Doe <span class="font-normal text-gray-400">&lt;jane@example.com&gt;</span></p>
                                <p class="text-xs text-gray-400">To: me &nbsp;·&nbsp; Today at 10:42</p>
                            </div>
                        </div>
                        <div class="flex gap-1">
                            <button class="p-1.5 rounded hover:bg-gray-100  dark:hover:bg-gray-800 text-gray-400" title="Reply">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
                                </svg>
                            </button>
                            <button class="p-1.5 rounded hover:bg-gray-100  dark:hover:bg-gray-800 text-gray-400" title="Forward">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 10H11a8 8 0 00-8 8v2m18-10l-6-6m6 6l-6 6"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div class="prose prose-sm text-gray-700 space-y-3">
                        <p>Hi,</p>
                        <p>Just confirming we're still on for the project kickoff tomorrow at 9am. I've booked the main meeting room and sent calendar invites to everyone on the team.</p>
                        <p>Agenda for the call:</p>
                        <ul class="list-disc pl-5 space-y-1">
                            <li>Introductions and roles</li>
                            <li>Project scope and timeline</li>
                            <li>Tooling and workflow decisions</li>
                            <li>Q&amp;A</li>
                        </ul>
                        <p>Let me know if anything needs to change.</p>
                        <p>Best,<br>Jane</p>
                    </div>

                    {# Reply box #}
                    <div class="mt-8 border border-gray-200  dark:border-gray-800 rounded-xl p-4 bg-white dark:bg-gray-900 shadow-sm">
                        <p class="text-xs text-gray-400 mb-2">Reply to Jane Doe</p>
                        <textarea rows="4" placeholder="Write a reply…" class="w-full text-sm text-gray-800 placeholder-gray-400 resize-none focus:outline-none"></textarea>
                        <div class="flex justify-end pt-2 border-t border-gray-100 mt-2">
                            <button class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-1.5 rounded-lg transition-colors">Send</button>
                        </div>
                    </div>
                </div>
            </main>

        </div>
    </div>
{% endblock %}


