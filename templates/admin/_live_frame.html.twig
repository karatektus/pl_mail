{# Auto-refreshed live panels. Wrapped in the same turbo-frame id so
   frame.reload() swaps the whole block. #}

{% macro dot(healthy) %}
    <span class="inline-block w-2 h-2 rounded-full {{ healthy ? 'bg-emerald-500' : 'bg-red-500' }}" aria-hidden="true"></span>
{% endmacro %}

{% macro card_open(icon, title) %}
    <section class="rounded-pane border border-line bg-pane-soft overflow-hidden">
        <div class="flex items-center gap-2.5 px-5 h-11 border-b border-line">
            <i class="fa-solid {{ icon }} text-xs text-zinc-400" aria-hidden="true"></i>
            <h2 class="text-sm font-semibold text-ink">{{ title }}</h2>
        </div>
{% endmacro %}

{% import _self as ui %}

<turbo-frame id="admin-live">

    <div class="space-y-6">

        {# ── Processes ─────────────────────────────────────────────────── #}
        {{ ui.card_open('fa-heart-pulse', 'admin.processes.heading'|trans) }}
            {% if heartbeats|length == 0 %}
                <p class="px-5 py-4 text-sm text-ink-faint">{{ 'admin.processes.empty'|trans }}</p>
            {% else %}
                <table class="w-full text-sm">
                    <thead>
                        <tr class="text-left text-xs text-ink-faint">
                            <th class="px-5 py-2 font-medium"></th>
                            <th class="px-2 py-2 font-medium">{{ 'admin.processes.type'|trans }}</th>
                            <th class="px-2 py-2 font-medium">{{ 'admin.processes.key'|trans }}</th>
                            <th class="px-2 py-2 font-medium">{{ 'admin.processes.pid'|trans }}</th>
                            <th class="px-2 py-2 font-medium">{{ 'admin.processes.last_beat'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in heartbeats %}
                            <tr class="border-t border-line text-ink-soft">
                                <td class="px-5 py-2 w-8">{{ ui.dot(row.healthy) }}</td>
                                <td class="px-2 py-2 font-mono text-xs">{{ row.type }}</td>
                                <td class="px-2 py-2 font-mono text-xs">{{ row.key }}</td>
                                <td class="px-2 py-2 font-mono text-xs">{{ row.pid ?? '—' }}</td>
                                <td class="px-2 py-2 text-xs {{ row.healthy ? '' : 'text-danger' }}">
                                    {{ row.age }} {{ 'admin.ago'|trans }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </section>

        <div class="grid md:grid-cols-2 gap-6">

            {# ── Gmail webhooks ────────────────────────────────────────── #}
            {{ ui.card_open('fa-satellite-dish', 'admin.webhooks.heading'|trans) }}
                {% if webhooks|length == 0 %}
                    <p class="px-5 py-4 text-sm text-ink-faint">{{ 'admin.webhooks.empty'|trans }}</p>
                {% else %}
                    <div class="divide-y divide-line">
                        {% for row in webhooks %}
                            <div class="px-5 py-3 text-sm">
                                <div class="flex items-center gap-2">
                                    {{ ui.dot(row.watchActive) }}
                                    <span class="font-medium text-ink">{{ row.account.email }}</span>
                                </div>
                                <dl class="mt-1.5 grid grid-cols-[auto_1fr] gap-x-3 gap-y-0.5 text-xs text-ink-muted">
                                    <dt>{{ 'admin.webhooks.watch_expiry'|trans }}</dt>
                                    <dd class="{{ row.watchActive ? '' : 'text-danger' }}">
                                        {{ row.watchExpiry ? row.watchExpiry|date('Y-m-d H:i') : 'admin.webhooks.none'|trans }}
                                    </dd>
                                    <dt>{{ 'admin.webhooks.last_push'|trans }}</dt>
                                    <dd>{{ row.lastPushAt ? (row.lastPushAge ~ ' ' ~ 'admin.ago'|trans) : 'admin.webhooks.never'|trans }}</dd>
                                    <dt>{{ 'admin.webhooks.history_id'|trans }}</dt>
                                    <dd class="font-mono">{{ row.historyId ?? '—' }}</dd>
                                </dl>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </section>

            {# ── OAuth token health ────────────────────────────────────── #}
            {{ ui.card_open('fa-key', 'admin.tokens.heading'|trans) }}
                {% if tokenHealth|length == 0 %}
                    <p class="px-5 py-4 text-sm text-ink-faint">{{ 'admin.tokens.empty'|trans }}</p>
                {% else %}
                    <div class="divide-y divide-line">
                        {% for row in tokenHealth %}
                            <div class="px-5 py-3 text-sm">
                                <div class="flex items-center gap-2">
                                    {{ ui.dot(row.healthy) }}
                                    <span class="font-medium text-ink">{{ row.account.email }}</span>
                                    <span class="ml-auto text-xs text-ink-faint">
                                        {{ row.lastRefreshAt ? (row.lastRefreshAge ~ ' ' ~ 'admin.ago'|trans) : '—' }}
                                    </span>
                                </div>
                                {% if row.error %}
                                    <p class="mt-1 text-xs text-danger font-mono break-all">{{ row.error }}</p>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </section>

        </div>

        {# ── Messenger queues ──────────────────────────────────────────── #}
        {{ ui.card_open('fa-list-check', 'admin.queues.heading'|trans) }}
            {% if queueStats|length == 0 %}
                <p class="px-5 py-4 text-sm text-ink-faint">{{ 'admin.queues.empty'|trans }}</p>
            {% else %}
                <table class="w-full text-sm">
                    <thead>
                        <tr class="text-left text-xs text-ink-faint">
                            <th class="px-5 py-2 font-medium">{{ 'admin.queues.queue'|trans }}</th>
                            <th class="px-2 py-2 font-medium">{{ 'admin.queues.pending'|trans }}</th>
                            <th class="px-2 py-2 font-medium">{{ 'admin.queues.oldest'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in queueStats %}
                            <tr class="border-t border-line text-ink-soft">
                                <td class="px-5 py-2 font-mono text-xs">{{ row.queue }}</td>
                                <td class="px-2 py-2">{{ row.pending }}</td>
                                <td class="px-2 py-2 text-xs">
                                    {% if row.oldestAgeSeconds is not null and row.oldestAgeSeconds > 300 %}
                                        <span class="text-warning">{{ (row.oldestAgeSeconds // 60) }}m</span>
                                    {% elseif row.oldestAgeSeconds is not null %}
                                        {{ row.oldestAgeSeconds }}s
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </section>

        {# ── Failed messages ───────────────────────────────────────────── #}
        {{ ui.card_open('fa-triangle-exclamation', 'admin.failed.heading'|trans) }}
            {% if failedMessages|length == 0 %}
                <p class="px-5 py-4 text-sm text-ink-faint">{{ 'admin.failed.empty'|trans }}</p>
            {% else %}
                <div class="divide-y divide-line">
                    {% for row in failedMessages %}
                        <div class="px-5 py-3 text-sm">
                            <div class="flex items-start gap-3">
                                <div class="min-w-0 flex-1">
                                    <p class="font-mono text-xs text-ink truncate">{{ row.class }}</p>
                                    {% if row.error %}
                                        <p class="mt-1 text-xs text-danger font-mono break-all line-clamp-2">{{ row.error }}</p>
                                    {% endif %}
                                    {% if row.failedAt %}
                                        <p class="mt-1 text-xs text-ink-faint">{{ row.failedAt|date('Y-m-d H:i:s') }}</p>
                                    {% endif %}
                                </div>
                                <div class="flex items-center gap-2 shrink-0">
                                    <form method="post" action="{{ path('app_admin_failed_retry', { id: row.id }) }}" data-turbo-frame="_top">
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_failed_' ~ row.id) }}">
                                        <button type="submit"
                                                class="inline-flex items-center gap-1.5 px-2.5 h-8 rounded-lg text-xs font-medium bg-accent hover:bg-accent-strong text-white transition-colors cursor-pointer">
                                            <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
                                            {{ 'admin.failed.retry'|trans }}
                                        </button>
                                    </form>
                                    <form method="post" action="{{ path('app_admin_failed_delete', { id: row.id }) }}" data-turbo-frame="_top"
                                          data-turbo-confirm="{{ 'admin.failed.delete_confirm'|trans }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_failed_' ~ row.id) }}">
                                        <button type="submit"
                                                class="inline-flex items-center gap-1.5 px-2.5 h-8 rounded-lg text-xs font-medium btn-quiet hover:text-danger hover:bg-danger-soft transition-colors cursor-pointer"
                                            <i class="fa-solid fa-trash" aria-hidden="true"></i>
                                            {{ 'admin.failed.delete'|trans }}
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </section>

        <div class="grid md:grid-cols-2 gap-6">

            {# ── Accounts ──────────────────────────────────────────────── #}
            {{ ui.card_open('fa-at', 'admin.accounts.heading'|trans) }}
                <table class="w-full text-sm">
                    <thead>
                        <tr class="text-left text-xs text-ink-faint">
                            <th class="px-5 py-2 font-medium">{{ 'admin.accounts.account'|trans }}</th>
                            <th class="px-2 py-2 font-medium">{{ 'admin.accounts.threads'|trans }}</th>
                            <th class="px-2 py-2 font-medium">{{ 'admin.accounts.messages'|trans }}</th>
                            <th class="px-2 py-2 font-medium">{{ 'admin.accounts.last_activity'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in accountOverview %}
                            <tr class="border-t border-line text-ink-soft {{ row.is_active ? '' : 'opacity-50' }}">
                                <td class="px-5 py-2 text-xs truncate max-w-40">{{ row.email }}</td>
                                <td class="px-2 py-2 text-xs">{{ row.threads }}</td>
                                <td class="px-2 py-2 text-xs">{{ row.messages }}</td>
                                <td class="px-2 py-2 text-xs">{{ row.last_activity ? row.last_activity|date('Y-m-d H:i') : '—' }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </section>

            {# ── Table sizes ───────────────────────────────────────────── #}
            {{ ui.card_open('fa-database', 'admin.tables.heading'|trans) }}
                <table class="w-full text-sm">
                    <tbody>
                        {% for row in tableSizes %}
                            <tr class="border-t border-line first:border-t-0 text-ink-soft">
                                <td class="px-5 py-2 font-mono text-xs">{{ row.table }}</td>
                                <td class="px-2 py-2 text-xs text-right pr-5">{{ row.size }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </section>

        </div>

    </div>

</turbo-frame>
