{% extends '_layout/app.html.twig' %}

{% block title %}{{ 'admin.title'|trans }} — {{ 'app.name'|trans }}{% endblock %}

{% block body %}
    {% set navActive = 'flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium bg-raised text-ink' %}
    {% set navInactive = 'flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-ink-muted hover:bg-hover transition-colors' %}

    <div class="h-screen overflow-hidden app-bg"
         data-controller="sidebar-drawer">

        {# Mobile backdrop #}
        <div data-sidebar-drawer-target="backdrop" data-action="click->sidebar-drawer#backdropClick"
             class="md:hidden fixed inset-0 z-30 bg-black/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-200"
             aria-hidden="true"></div>

        {# Mobile sidebar drawer #}
        <div data-sidebar-drawer-target="drawer"
             class="md:hidden fixed inset-y-0 left-0 z-40 w-64 p-3 -translate-x-full transition-transform duration-200 ease-out">
            {% include '_partials/_sidebar.html.twig' with { _drawerMode: true } %}
        </div>

        <div class="flex h-full flex-col p-3 gap-3">

            {% include '_partials/_topbar.html.twig' with { _showBurger: true } %}

            <div class="flex flex-1 gap-3 overflow-hidden">

                {# Sidebar — desktop #}
                <div class="hidden md:flex">
                    {% include '_partials/_sidebar.html.twig' %}
                </div>

                {# Main content pane — admin dashboard #}
                <div class="flex flex-1 overflow-hidden pane">
                    <div class="flex flex-col flex-1 overflow-hidden">

                        {# Pane header #}
                        <div class="flex items-center gap-3 px-6 h-14 border-b border-line shrink-0">
                            <i class="fa-solid fa-gauge-high text-zinc-400" aria-hidden="true"></i>
                            <h1 class="text-base font-semibold text-ink">{{ 'admin.title'|trans }}</h1>
                            {% if section != 'logs' %}
                                <span class="ml-auto text-xs text-ink-faint">{{ 'admin.refresh_hint'|trans }}</span>
                            {% endif %}
                        </div>

                        {# Scrollable body: section nav + content.
                           Two grid children only — nav and ONE content wrapper. #}
                        <div class="flex-1 overflow-y-auto">
                            <div class="grid grid-cols-1 md:grid-cols-[180px_1fr] gap-6 px-6 py-6">

                                {# Section nav #}
                                <nav class="flex md:flex-col gap-1 flex-wrap">
                                    <a href="{{ path('app_admin_dashboard', { section: 'system' }) }}"
                                       class="{{ section == 'system' ? navActive : navInactive }}">
                                        <i class="fa-solid fa-heart-pulse w-4 {{ section == 'system' ? 'text-zinc-400' : '' }}" aria-hidden="true"></i>
                                        {{ 'admin.nav.system'|trans }}
                                    </a>
                                    <a href="{{ path('app_admin_dashboard', { section: 'database' }) }}"
                                       class="{{ section == 'database' ? navActive : navInactive }}">
                                        <i class="fa-solid fa-database w-4 {{ section == 'database' ? 'text-zinc-400' : '' }}" aria-hidden="true"></i>
                                        {{ 'admin.nav.database'|trans }}
                                    </a>
                                    <a href="{{ path('app_admin_dashboard', { section: 'logs' }) }}"
                                       class="{{ section == 'logs' ? navActive : navInactive }}">
                                        <i class="fa-solid fa-scroll w-4 {{ section == 'logs' ? 'text-zinc-400' : '' }}" aria-hidden="true"></i>
                                        {{ 'admin.nav.logs'|trans }}
                                    </a>
                                </nav>

                                {# Single content wrapper — second (and last) grid child.
                                   Only the active section's frame is rendered, so only
                                   one loads/polls at a time. #}
                                <div class="min-w-0">

                                    {% if section == 'database' %}

                                        <turbo-frame id="admin-db"
                                                     src="{{ path('app_admin_db') }}"
                                                     loading="lazy"
                                                     data-controller="auto-refresh"
                                                     data-auto-refresh-interval-value="20000">
                                            <div class="py-10 text-center text-sm text-ink-faint">
                                                <i class="fa-solid fa-circle-notch fa-spin mr-2" aria-hidden="true"></i>{{ 'admin.loading'|trans }}
                                            </div>
                                        </turbo-frame>

                                    {% elseif section == 'logs' %}

                                        <turbo-frame id="admin-logs"
                                                     src="{{ path('app_admin_logs') }}"
                                                     loading="lazy">
                                            <div class="py-10 text-center text-sm text-ink-faint">
                                                <i class="fa-solid fa-circle-notch fa-spin mr-2" aria-hidden="true"></i>{{ 'admin.loading'|trans }}
                                            </div>
                                        </turbo-frame>

                                    {% else %}

                                        <turbo-frame id="admin-live"
                                                     src="{{ path('app_admin_live') }}"
                                                     loading="lazy"
                                                     data-controller="auto-refresh"
                                                     data-auto-refresh-interval-value="10000">
                                            <div class="py-10 text-center text-sm text-ink-faint">
                                                <i class="fa-solid fa-circle-notch fa-spin mr-2" aria-hidden="true"></i>{{ 'admin.loading'|trans }}
                                            </div>
                                        </turbo-frame>

                                    {% endif %}

                                </div>

                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
