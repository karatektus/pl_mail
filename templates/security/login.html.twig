{# templates/security/login.html.twig #}
{% extends '_layout/app.html.twig' %}

{% block title %}{{ 'login.page_title'|trans }} — {{ 'app.name'|trans }}{% endblock %}

{% block body %}
    <div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-950 px-4">
        <div class="w-full max-w-sm">

            {# Logo #}
            <div class="flex flex-col items-center mb-8">
                <div class="flex items-center gap-2 mb-2">
                    <i class="fa-solid fa-envelope text-blue-600 text-2xl" aria-hidden="true"></i>
                    <span class="text-xl font-semibold text-ink">{{ 'app.name'|trans }}</span>
                </div>
                <p class="text-sm text-ink-muted">{{ 'login.tagline'|trans }}</p>
            </div>

            {# Error #}
            {% if error %}
                <div class="mb-4 px-4 py-3 rounded-lg alert-danger text-sm text-danger">
                    {{ error.messageKey | trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {# Card #}
            <div class="bg-surface rounded-pane shadow-sm border border-line p-8">

                <form method="post">

                    <div class="space-y-4">
                        <div>
                            <label for="inputEmail" class="block text-sm font-medium text-ink-soft mb-1.5">
                                {{ 'login.form.email'|trans }}
                            </label>
                            <input
                                type="email"
                                id="inputEmail"
                                name="email"
                                value="{{ last_username|default('APP_DEV_USER_EMAIL'|get_env) }}"
                                autocomplete="email"
                                autofocus
                                required
                                class="w-full px-3 py-2 text-sm rounded-lg border border-field bg-field text-ink placeholder:text-ink-faint focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                                placeholder="you@example.com"
                            >
                        </div>

                        <div>
                            <div class="flex items-baseline justify-between mb-1.5">
                                <label for="password" class="block text-sm font-medium text-ink-soft">
                                    {{ 'login.form.password'|trans }}
                                </label>
                                <a href="#" class="text-xs text-accent hover:underline">
                                    {{ 'login.form.forgot_password'|trans }}
                                </a>
                            </div>
                            <input
                                type="password"
                                id="password"
                                name="password"
                                autocomplete="current-password"
                                required
                                value="{{ 'APP_DEV_USER_PASSWORD'|get_env }}"
                                class="w-full px-3 py-2 text-sm rounded-lg border border-field bg-field text-ink placeholder:text-ink-faint focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                                placeholder="••••••••"
                            >
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button
                        type="submit"
                        class="mt-6 w-full bg-accent hover:bg-accent-strong text-white text-sm font-medium py-2 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 ring-offset-surface"
                    >
                        {{ 'login.form.submit'|trans }}
                    </button>

                </form>
            </div>

            {# Register link #}
            <p class="text-center text-sm text-ink-muted mt-6">
                {{ 'login.register.prompt'|trans }}
                <a href="#" class="text-accent font-medium hover:underline">
                    {{ 'login.register.link'|trans }}
                </a>
                <span class="block text-xs text-ink-faint mt-1">{{ 'login.register.coming_soon'|trans }}</span>
            </p>

        </div>
    </div>
{% endblock %}
