{# templates/security/login.html.twig #}
{% extends '_layout/app.html.twig' %}

{% block title %}Sign in — Mail{% endblock %}

{% block body %}
    <div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-950 px-4">
        <div class="w-full max-w-sm">

            {# Logo #}
            <div class="flex flex-col items-center mb-8">
                <div class="flex items-center gap-2 mb-2">
                    <svg class="w-7 h-7 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                        <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                    </svg>
                    <span class="text-xl font-semibold text-gray-900 dark:text-gray-100">Mail</span>
                </div>
                <p class="text-sm text-gray-500 dark:text-gray-400">Sign in to your account</p>
            </div>

            {# Error #}
            {% if error %}
                <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 text-sm text-red-700 dark:text-red-400">
                    {{ error.messageKey | trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {# Card #}
            <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-8">

                <form method="post">

                    <div class="space-y-4">
                        <div>
                            <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">
                                Email address
                            </label>
                            <input
                                type="email"
                                id="inputEmail"
                                name="email"
                                value="{{ last_username|default('APP_DEV_USER_EMAIL'|get_env) }}"
                                autocomplete="email"
                                autofocus
                                required
                                class="w-full px-3 py-2 text-sm rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                                placeholder="you@example.com"
                            >
                        </div>

                        <div>
                            <div class="flex items-baseline justify-between mb-1.5">
                                <label for="password" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                                    Password
                                </label>
                                <a href="#" class="text-xs text-blue-600 dark:text-blue-400 hover:underline">
                                    Forgot password?
                                </a>
                            </div>
                            <input
                                type="password"
                                id="password"
                                name="password"
                                autocomplete="current-password"
                                required
                                value="{{ 'APP_DEV_USER_PASSWORD'|get_env }}"
                                class="w-full px-3 py-2 text-sm rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                                placeholder="••••••••"
                            >
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button
                        type="submit"
                        class="mt-6 w-full bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
                    >
                        Sign in
                    </button>

                </form>
            </div>

            {# Register link #}
            <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-6">
                Don't have an account?
                <a href="#" class="text-blue-600 dark:text-blue-400 font-medium hover:underline">
                    Create one
                </a>
                <span class="block text-xs text-gray-400 dark:text-gray-600 mt-1">Registration coming soon.</span>
            </p>

        </div>
    </div>
{% endblock %}
