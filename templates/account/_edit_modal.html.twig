{% extends '_layout/app.html.twig' %}

{% block body %}
    <turbo-frame id="modal">
        <template data-modal-frame-title>{{ 'settings.accounts.edit'|trans }}</template>

        {{ form_start(form, {
            attr: {
                'data-turbo': 'true',
                'data-controller': 'imap-preset connection-test',
                'data-connection-test-url-value': path('app_account_test_connection'),
                'data-connection-test-csrf-value': csrf_token('account_test'),
                'data-connection-test-account-id-value': account.id,
                class: 'flex flex-col min-h-0',
            }
        }) }}

        <div class="overflow-y-auto px-5 py-5 space-y-5">
            {% include 'account/_fields.html.twig' with { form: form, mode: 'edit' } %}
        </div>

        <div class="flex items-center justify-end gap-2 px-5 py-3.5 border-t border-line bg-sunken">
            <button type="button" data-action="click->modal#close"
                    class="px-3 h-9 rounded-lg text-sm font-medium text-ink-soft hover:bg-hover transition-colors cursor-pointer">
                {{ 'form.cancel'|trans }}
            </button>
            <button type="submit"
                    class="px-4 h-9 rounded-lg text-sm font-medium bg-accent hover:bg-accent-strong text-white transition-colors cursor-pointer">
                {{ 'form.submit'|trans }}
            </button>
        </div>

        {{ form_end(form) }}
    </turbo-frame>
{% endblock %}
