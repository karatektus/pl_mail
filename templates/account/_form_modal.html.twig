{% extends '_layout/app.html.twig' %}

{% block body %}
    <turbo-frame id="modal">
        <template data-modal-frame-title>{{ 'account.add_title'|trans }}</template>

        {{ form_start(form, {
            attr: {
                'data-turbo': 'true',
                'data-controller': 'account-form imap-preset connection-test',
                'data-connection-test-url-value': path('app_account_test_connection'),
                'data-connection-test-csrf-value': csrf_token('account_test'),
                class: 'flex flex-col min-h-0',
            }
        }) }}

        {# ── Tab bar ─────────────────────────────────────────────────────── #}
        <div class="flex border-b border-line px-5 -mt-px bg-sunken">
            <button
                type="button"
                data-account-form-target="tab"
                data-action="click->account-form#switchTab"
                data-panel="imap"
                class="tab-btn active-tab px-1 py-3 mr-5px text-sm font-medium border-b-2 transition-colors duration-100 cursor-pointer"
            >{{ 'account.tabs.imap'|trans }}</button>
            <button
                type="button"
                data-account-form-target="tab"
                data-action="click->account-form#switchTab"
                data-panel="oauth"
                class="tab-btn px-1 py-3 text-sm font-medium border-b-2 border-transparent -mb-px text-ink-faint hover:text-ink transition-colors duration-100 cursor-pointer"
            >{{ 'account.tabs.oauth'|trans }}</button>
        </div>

        {# ── Scrollable body ─────────────────────────────────────────────── #}
        <div class="overflow-y-auto">

            {# IMAP / SMTP panel #}
            <div data-account-form-target="panel" data-panel="imap" class="px-5 py-5 space-y-5">
                {% include 'account/_fields.html.twig' with { form: form, mode: 'new' } %}
            </div>

            {# OAuth panel #}
            <div data-account-form-target="panel" data-panel="oauth" class="hidden px-5 py-5 space-y-4">

                <div class="flex items-start gap-3 rounded-xl
                            alert-info
                            px-4 py-3 text-sm text-accent">
                    <i class="fa-solid fa-circle-info mt-0.5 shrink-0 text-accent/70" aria-hidden="true"></i>
                    <p>{{ 'account.oauth.info'|trans }}</p>
                </div>

                <div class="space-y-2.5">
                    <a
                        href="{{ path('app_oauth_connect', { provider: 'google' }) }}"
                        data-turbo="false"
                        class="flex items-center gap-3 mb-3 w-full px-4 py-2.5 rounded-xl
                        border border-line
                        text-sm font-medium text-ink-soft
                        hover:bg-hover transition-colors"
                        >
                        <i class="fa-brands fa-google shrink-0" aria-hidden="true"></i>
                        {{ 'account.oauth.google'|trans }}
                    </a>

                    <a
                        href="{{ path('app_oauth_connect', { provider: 'microsoft' }) }}"
                        data-turbo="false"
                        class="flex items-center gap-3 w-full px-4 py-2.5 rounded-xl
                        border border-line
                        text-sm font-medium text-ink-soft
                        hover:bg-hover transition-colors"
                        >
                        <i class="fa-brands fa-microsoft shrink-0" aria-hidden="true"></i>
                        {{ 'account.oauth.microsoft'|trans }}
                    </a>
                </div>

                <p class="text-xs text-ink-faint">{{ 'account.oauth.wip'|trans }}</p>

            </div>

        </div>

        {# ── Footer ──────────────────────────────────────────────────────── #}
        <div class="flex items-center justify-end gap-2 px-5 py-3.5 border-t border-line bg-sunken">
            <button type="button" data-action="click->modal#close"
                    class="px-3 h-9 rounded-lg text-sm font-medium text-ink-soft hover:bg-hover transition-colors cursor-pointer">
                {{ 'form.cancel'|trans }}
            </button>
            <button type="submit"
                    data-account-form-target="submitBtn"
                    class="px-4 h-9 rounded-lg text-sm font-medium bg-accent hover:bg-accent-strong text-white transition-colors cursor-pointer">
                {{ 'form.submit'|trans }}
            </button>
        </div>

        {{ form_end(form) }}
    </turbo-frame>
{% endblock %}
