{# mail/inbox.html.twig #}
{% extends '_layout/_mailbox.html.twig' %}

{% block title %}
    {% set _unread = sidebarCounts.forRole(enum('App\\Domain\\Enum\\LabelRole').Inbox) %}
    {{ _unread > 0 ? '('~_unread~')' }} {{ 'Inbox'|trans }} — {{ 'app.name'|trans }}
{% endblock %}

{% block inbox_tabs %}
    <div class="border-b border-line px-1">
        <nav class="flex text-sm">
            {% for tabCase in tabs %}
                {% set isActive = tabCase === tab %}
                {% set unreadCount = tabCounts[tabCase.value]|default(0) %}

                <a
                    href="{{ path('app_mail_inbox', {tab: tabCase.value}) }}"
                    data-turbo-frame="inbox-list-frame"
                    class="px-4 py-3 font-medium border-b-2 -mb-px transition-colors {{ isActive ? 'text-blue-600 border-blue-600' : 'text-ink-muted hover:text-gray-700 border-transparent hover:border-gray-300' }}"
                >
                    {{ ('tabs.' ~ tabCase.value)|trans }}
                    {% if unreadCount > 0 %}
                        <span class="ml-1 text-xs {{ isActive ? 'text-blue-600' : 'text-gray-400' }}">{{ unreadCount }}</span>
                    {% endif %}
                </a>
            {% endfor %}
        </nav>
    </div>
{% endblock %}

{% block message_list %}
    {% if threads is empty %}
        <li class="px-4 py-8 text-center text-sm text-ink-faint">
            {{ 'inbox.empty'|trans }}
        </li>
    {% else %}
        {% for thread in threads %}
            {% include '_partials/_thread_row.html.twig' with {
                thread: thread,
            } %}
        {% endfor %}
    {% endif %}
{% endblock %}
