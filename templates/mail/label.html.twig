{#
mail/label.html.twig — thread list for a custom label.
#}
{% extends '_layout/_mailbox.html.twig' %}

{% block title %}
    {% set _unread = sidebarCounts.forLabel(label) %}
    {{ _unread > 0 ? '('~_unread~')' }} {{ label.fullName }} — {{ 'app.name'|trans }}
{% endblock %}

{% block inbox_tabs %}
    <div class="px-4 py-2.5 border-b border-line">
        <h2 class="text-sm font-semibold text-ink-soft">{{ label.fullName }}</h2>
    </div>
{% endblock %}

{% block message_list %}
    {% if threads is empty %}
        <li class="px-4 py-8 text-center text-sm text-ink-faint">
            {{ 'label.empty'|trans }}
        </li>
    {% else %}
        {% for thread in threads %}
            {% include '_partials/_thread_row.html.twig' with { thread: thread } %}
        {% endfor %}
    {% endif %}
{% endblock %}
