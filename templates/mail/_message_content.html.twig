{# mail/_message_content.html.twig #}
<div class="flex items-center gap-2 px-4 py-2 border-b border-line">
    <button
        type="button"
        data-action="click->mail-pane#close"
        aria-label="{{ 'message.back'|trans }}"
        class="p-2 rounded-lg text-gray-400 hover:text-ink-soft hover:bg-hover transition-colors"
    >
        <i class="fa-solid fa-arrow-left w-4 h-4" aria-hidden="true"></i>
    </button>
    <span class="text-sm text-ink-faint truncate">{{ message.mailbox.name }}</span>
</div>

<div class="flex-1 overflow-y-auto">
    <div class="max-w-3xl mx-auto px-6 py-6">

        <h1 class="text-xl font-semibold text-ink mb-4">
            {{ message.subject ?: ('thread.no_subject'|trans) }}
        </h1>

        <div class="flex items-start justify-between border-b border-line pb-4 mb-4">
            <div>
                <p class="text-sm font-medium text-ink">
                    {{ message.fromName ?: message.fromAddress }}
                </p>
                <p class="text-xs text-ink-faint">
                    {{ message.fromAddress }}
                </p>
            </div>
            <p class="text-xs text-ink-faint flex-shrink-0">
                {{ message.receivedAt ? message.receivedAt|date('M j, Y, g:i a') : '' }}
            </p>
        </div>

        {% if message.bodyHtmlSafe %}
            <div class="rounded-lg bg-white text-gray-900 p-5 overflow-x-auto">
                {{ message.bodyHtmlSafe|raw }}
            </div>
        {% else %}
            <div class="whitespace-pre-wrap text-sm text-ink-soft">
                {{ message.bodyText }}
            </div>
        {% endif %}

        {% if message.hasAttachments %}
            <div class="mt-6 pt-4 border-t border-line">
                <p class="text-xs font-medium text-ink-faint mb-2">{{ 'message.attachments'|trans }}</p>
                <div class="flex flex-wrap gap-2">
                    {% for part in message.messageParts %}
                        {% if not part.isInline %}
                            <a
                                href="{{ path('app_mail_attachment', { id: part.id }) }}?download=1"
                                class="inline-flex items-center gap-2 px-3 py-2 rounded-lg text-xs
                        bg-sunken border border-line
                        text-ink-soft
                        hover:bg-hover transition-colors"
                            >
                                <i class="fa-solid fa-paperclip text-[11px]" aria-hidden="true"></i>
                                <span class="truncate max-w-[12rem]">{{ part.filename ?: 'attachment' }}</span>
                            </a>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        {% endif %}

    </div>
</div>
