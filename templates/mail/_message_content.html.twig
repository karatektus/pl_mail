{# mail/_message_content.html.twig #}
<div class="flex items-center gap-2 px-4 py-2 border-b border-gray-200/60 dark:border-white/10">
    <button
        type="button"
        data-action="click->mail-pane#close"
        aria-label="{{ 'message.back'|trans }}"
        class="p-2 rounded-lg text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
    >
        <i class="fa-solid fa-arrow-left w-4 h-4" aria-hidden="true"></i>
    </button>
    <span class="text-sm text-gray-400 dark:text-gray-600 truncate">{{ message.mailbox.name }}</span>
</div>

<div class="flex-1 overflow-y-auto">
    <div class="max-w-3xl mx-auto px-6 py-6">

        <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-4">
            {{ message.subject ?: ('thread.no_subject'|trans) }}
        </h1>

        <div class="flex items-start justify-between border-b border-gray-100 dark:border-gray-800 pb-4 mb-4">
            <div>
                <p class="text-sm font-medium text-gray-900 dark:text-gray-100">
                    {{ message.fromName ?: message.fromAddress }}
                </p>
                <p class="text-xs text-gray-400 dark:text-gray-600">
                    {{ message.fromAddress }}
                </p>
            </div>
            <p class="text-xs text-gray-400 dark:text-gray-600 flex-shrink-0">
                {{ message.receivedAt ? message.receivedAt|date('M j, Y, g:i a') : '' }}
            </p>
        </div>

        {% if message.bodyHtml %}
            <div class="prose prose-sm dark:prose-invert max-w-none">
                {{ message.bodyHtml|resolve_cid(message)|raw }}
            </div>
        {% else %}
            <div class="whitespace-pre-wrap text-sm text-gray-700 dark:text-gray-300">
                {{ message.bodyText }}
            </div>
        {% endif %}
        {% if message.hasAttachments %}
            <div class="mt-6 pt-4 border-t border-gray-100 dark:border-gray-800">
                <p class="text-xs font-medium text-gray-400 dark:text-gray-600 mb-2">{{ 'message.attachments'|trans }}</p>
                <div class="flex flex-wrap gap-2">
                    {% for part in message.messageParts %}
                        {% if not part.isInline %}
                        href="{{ path('app_mail_attachment', { id: part.id }) }}?download=1"
                        class="inline-flex items-center gap-2 px-3 py-2 rounded-lg text-xs
                        bg-gray-100 dark:bg-white/5 border border-gray-200/60 dark:border-white/10
                        text-gray-700 dark:text-gray-300
                        hover:bg-gray-200 dark:hover:bg-white/10 transition-colors"
                        >
                        <i class="fa-solid fa-paperclip text-[11px]" aria-hidden="true"></i>
                        <span class="truncate max-w-[12rem]">{{ part.filename ?: 'attachment' }}</span>
                        </a>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        {% endif %}

    </div>
</div>
