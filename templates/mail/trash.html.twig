{% extends '_layout/_mailbox.html.twig' %}

{% block title %}
    {% set _unread = sidebarCounts.forRole(enum('App\\Domain\\Enum\\LabelRole').Trash) %}
    {{ _unread > 0 ? '('~_unread~')' }} {{ 'Trash'|trans }} — {{ 'app.name'|trans }}
{% endblock %}

{% block inbox_tabs %}
    <div class="px-4 py-2.5 border-b border-line">
        <h2 class="text-sm font-semibold text-ink-soft">{{ 'trash.heading'|trans }}</h2>
    </div>
{% endblock %}

{% block message_list %}
    {% if threads is empty %}
        <li class="px-4 py-8 text-center text-sm text-ink-faint">
            {{ 'trash.empty'|trans }}
        </li>
    {% else %}
        {% for thread in threads %}
            {% include '_partials/_thread_row.html.twig' with { thread: thread } %}
        {% endfor %}
    {% endif %}
{% endblock %}
