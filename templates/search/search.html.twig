{% extends '_layout/_mailbox.html.twig' %}

{% block title %}
    {% if q %}{{ q }} — Search{% else %}Search{% endif %} — {{ 'app.name'|trans }}
{% endblock %}

{% block inbox_tabs %}
    <div class="px-4 py-2.5 border-b border-line flex items-center gap-3">
        <h2 class="text-sm font-semibold text-ink-soft flex-1 min-w-0 truncate">
            {% if q %}
                Search results for <span class="text-accent">{{ q }}</span>
            {% else %}
                Search
            {% endif %}
        </h2>
        {% if total > 0 %}
            <span class="text-xs text-ink-faint flex-shrink-0">
                {{ total }} result{{ total != 1 ? 's' : '' }}
            </span>
        {% endif %}
    </div>

    {# Active filter pills — shown when structured operators were parsed #}
    {% if parsed is not null and not parsed.isEmpty %}
        <div class="flex flex-wrap gap-1.5 px-4 py-2 border-b border-line">
            {% if parsed.from %}
                {{ _self.pill('From', parsed.from, q) }}
            {% endif %}
            {% if parsed.to %}
                {{ _self.pill('To', parsed.to, q) }}
            {% endif %}
            {% if parsed.subject %}
                {{ _self.pill('Subject', parsed.subject, q) }}
            {% endif %}
            {% if parsed.hasAttachment %}
                {{ _self.pill('Has', 'attachment', q) }}
            {% endif %}
            {% if parsed.isUnread %}
                {{ _self.pill('Is', 'unread', q) }}
            {% endif %}
            {% if parsed.isRead %}
                {{ _self.pill('Is', 'read', q) }}
            {% endif %}
            {% if parsed.isStarred %}
                {{ _self.pill('Is', 'starred', q) }}
            {% endif %}
            {% if parsed.mailboxRole %}
                {{ _self.pill('In', parsed.mailboxRole, q) }}
            {% endif %}
            {% if parsed.after %}
                {{ _self.pill('After', parsed.after|date('Y-m-d'), q) }}
            {% endif %}
            {% if parsed.before %}
                {{ _self.pill('Before', parsed.before|date('Y-m-d'), q) }}
            {% endif %}
        </div>
    {% endif %}
{% endblock %}

{# Filter pill macro #}
{% macro pill(label, value, q) %}
    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium
                 bg-accent-soft text-accent border border-accent/20">
        <span class="text-accent">{{ label }}:</span>{{ value }}
    </span>
{% endmacro %}

{% block message_list %}
    {% if q == '' %}
        {# Empty state — no query yet #}
        <li class="flex flex-col items-center justify-center py-16 text-center px-4">
            <div class="w-12 h-12 rounded-full bg-sunken flex items-center justify-center mb-4">
                <i class="fa-solid fa-magnifying-glass text-ink-faint text-lg" aria-hidden="true"></i>
            </div>
            <p class="text-sm font-medium text-ink-muted">Search your mail</p>
            <p class="text-xs text-ink-faint mt-1 max-w-xs">
                Try <code class="bg-sunken px-1 rounded">from:alice</code>,
                <code class="bg-sunken px-1 rounded">has:attachment</code>,
                <code class="bg-sunken px-1 rounded">is:unread</code>, or just type a keyword.
            </p>
        </li>
    {% elseif threads is empty %}
        {# No results #}
        <li class="flex flex-col items-center justify-center py-16 text-center px-4">
            <div class="w-12 h-12 rounded-full bg-sunken flex items-center justify-center mb-4">
                <i class="fa-solid fa-magnifying-glass text-ink-faint text-lg" aria-hidden="true"></i>
            </div>
            <p class="text-sm font-medium text-ink-muted">No results for "{{ q }}"</p>
            <p class="text-xs text-ink-faint mt-1">Try different keywords or remove some filters.</p>
        </li>
    {% else %}
        {% for thread in threads %}
            {% include '_partials/_thread_row.html.twig' with { thread: thread } %}
        {% endfor %}
    {% endif %}
{% endblock %}
