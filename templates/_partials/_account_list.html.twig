{% for account in accounts %}
    {% set currentAccount = app.request.attributes.get('account') %}
    {% set isActive = currentAccount is not null and currentAccount == account.id %}
    <div data-controller="account-expand"
         data-account-expand-folders-url-value="{{ path('app_mail_account_folders', { account: account.id }) }}"
         data-account-expand-active-value="{{ isActive ? 'true' : 'false' }}">

        <div class="flex items-center" data-action="click->account-expand#toggle">
            <a
                href="{{ path('app_mail_account_mailbox', { account: account.id, mailbox: 'INBOX' }) }}"
                data-action="click->account-expand#stop"
                class="flex items-center gap-2 px-3 py-2 rounded-lg transition-colors flex-1 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800"
            >
                <span class="w-2 h-2 rounded-full flex-shrink-0 {{ account.isActive ? 'bg-green-400' : 'bg-gray-300 dark:bg-gray-700' }}"></span>
                <span class="truncate text-sm">{{ account.label ?: account.username }}</span>
            </a>
            <button
                type="button"
                data-action="click->account-expand#toggle"
                class="p-2 rounded-lg text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
            >
                <svg data-account-expand-target="chevron"
                     class="w-3 h-3 shrink-0 transition-transform duration-150 {{ isActive ? 'rotate-90' : '' }}"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </button>
        </div>

        <turbo-frame
            id="account-folders-{{ account.id }}"
            data-account-expand-target="frame"
            class="{{ isActive ? '' : 'hidden' }}"
        >
            {% if isActive %}
                <div class="pl-5 py-1 text-xs text-gray-400 dark:text-gray-600">Loading…</div>
            {% endif %}
        </turbo-frame>
    </div>
{% else %}
    <p class="px-3 py-2 text-sm text-gray-400 dark:text-gray-600 italic">No accounts yet</p>
{% endfor %}
