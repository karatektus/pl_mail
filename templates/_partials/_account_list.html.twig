{% set _drawerClose = _drawerClose is defined ? _drawerClose : '' %}

{% for account in accounts %}
    <div data-controller="account-expand"
         data-account-expand-folders-url-value="{{ path('app_mail_account_folders', { account: account.id }) }}"
         data-account-expand-active-value="false">

        {# The whole row toggles the label list — per-account "folders" are
           labels now, so there is no INBOX landing link anymore. #}
        <div class="flex items-center cursor-pointer rounded-lg hover:bg-hover transition-colors"
             data-action="click->account-expand#toggle">
            <div class="flex items-center gap-2 px-3 py-2 flex-1 min-w-0 text-gray-600 dark:text-gray-400">
                <span class="w-2 h-2 rounded-full flex-shrink-0 {{ account.isActive ? 'bg-green-400' : 'bg-gray-300 dark:bg-gray-700' }}"></span>
                <span class="truncate text-sm">{{ account.email ?: account.username }}</span>
            </div>
            <button
                type="button"
                aria-label="{{ 'sidebar.accounts.toggle'|trans }}"
                class="p-2 rounded-lg text-gray-400 pointer-events-none"
            >
                <i data-account-expand-target="chevron"
                   class="fa-solid fa-chevron-right text-xs shrink-0 transition-transform duration-150"></i>
            </button>
        </div>

        <turbo-frame
            id="account-folders-{{ account.id }}"
            data-account-expand-target="frame"
            class="hidden"
        >
        </turbo-frame>
    </div>
{% else %}
    <p class="px-3 py-2 text-sm text-ink-faint italic">{{ 'sidebar.accounts.none'|trans }}</p>
{% endfor %}
