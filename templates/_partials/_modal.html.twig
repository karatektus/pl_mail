
{# ── Backdrop + dialog wrapper ─────────────────────────────────────────────── #}
<div
    id="modal-backdrop"
    hidden
    data-modal-dialog
    data-controller="modal"
    data-action="click->modal#backdropClick modal:close->modal#close"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
    class="
        fixed inset-0 z-50
        flex items-center justify-center
        bg-black/40 backdrop-blur-sm
        p-4
    "
>
    {# ── Dialog panel ────────────────────────────────────────────────────────── #}
    <div class="
        relative w-full max-w-lg
        bg-white/80 dark:bg-gray-900/80
        backdrop-blur-xl
        rounded-2xl shadow-2xl shadow-black/20 dark:shadow-black/60
        flex flex-col
        max-h-[90vh]
        border border-white/60 dark:border-white/10
    ">

        {# ── Header ──────────────────────────────────────────────────────────────── #}
        <div class="
            flex items-center justify-between
            px-5 py-3.5
            border-b border-black/[0.06] dark:border-white/10
            bg-black/[0.03] dark:bg-black/20
            rounded-t-2xl
            shrink-0
        ">
            <h2
                id="modal-title"
                data-modal-title
                class="text-sm font-semibold text-gray-800 dark:text-gray-100 truncate"
            >
                {# Filled dynamically by the Stimulus controller or by the loaded frame #}
            </h2>

            <button
                type="button"
                data-action="click->modal#close"
                aria-label="{{ 'modal.close'|trans }}"
                class="
                    -mr-1 w-7 h-7 flex items-center justify-center rounded-lg
                    text-gray-400 dark:text-gray-500
                    hover:text-gray-700 dark:hover:text-gray-200
                    hover:bg-black/10 dark:hover:bg-white/10
                    transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500
                "
            >
                <i class="fa-solid fa-xmark text-sm" aria-hidden="true"></i>
            </button>
        </div>

        {# ── Turbo Frame — Turbo loads the form here ──────────────────────────── #}
        <turbo-frame
            id="modal"
            class="flex-1 overflow-y-auto min-h-0"
            loading="lazy"
        >
            <div
                data-modal-loading
                class="flex items-center justify-center h-32 text-gray-400 dark:text-gray-500"
                aria-live="polite"
                aria-label="{{ 'modal.loading'|trans }}"
            >
                <i class="fa-solid fa-circle-notch fa-spin text-2xl" aria-hidden="true"></i>
            </div>
        </turbo-frame>

    </div>{# /panel #}
</div>{# /backdrop #}
