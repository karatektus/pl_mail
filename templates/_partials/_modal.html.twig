{#
templates/_partials/_modal.html.twig
...
#}

{# ── Backdrop + dialog wrapper ─────────────────────────────────────────────── #}
<div
    id="modal-backdrop"
    hidden
    data-modal-dialog
    data-controller="modal"
    data-action="click->modal#backdropClick modal:close->modal#close"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
    class="
    fixed inset-0 z-50
    flex items-center justify-center
    bg-black/50 backdrop-blur-sm
    p-4
  "
>
    {# ── Dialog panel ────────────────────────────────────────────────────────── #}
    <div class="
    relative w-full max-w-lg
    bg-white dark:bg-zinc-900
    rounded-xl shadow-2xl
    flex flex-col
    max-h-[90vh]
    ring-1 ring-black/10 dark:ring-white/10
  ">

        {# ── Header ──────────────────────────────────────────────────────────────── #}
        <div class="
      flex items-center justify-between
      px-6 py-4
      border-b border-zinc-200 dark:border-zinc-700
      shrink-0
    ">
            <h2
                id="modal-title"
                data-modal-title
                class="text-base font-semibold text-zinc-900 dark:text-zinc-100 truncate"
            >
                {# Filled dynamically by the Stimulus controller or by the loaded frame #}
            </h2>

            <button
                type="button"
                data-action="click->modal#close"
                aria-label="{{ 'modal.close'|trans }}"
                class="
          -mr-1 rounded-lg p-1.5
          text-zinc-400 hover:text-zinc-700 dark:hover:text-zinc-200
          hover:bg-zinc-100 dark:hover:bg-zinc-800
          transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500
        "
            >
                <i class="fa-solid fa-xmark" aria-hidden="true"></i>
            </button>
        </div>

        {# ── Turbo Frame — Turbo loads the form here ──────────────────────────── #}
        <turbo-frame
            id="modal"
            class="flex-1 overflow-y-auto"
            loading="lazy"
        >
            <div
                data-modal-loading
                class="flex items-center justify-center h-32 text-zinc-400 dark:text-zinc-500"
                aria-live="polite"
                aria-label="{{ 'modal.loading'|trans }}"
            >
                <i class="fa-solid fa-circle-notch fa-spin text-2xl" aria-hidden="true"></i>
            </div>
        </turbo-frame>

    </div>{# /panel #}
</div>{# /backdrop #}
