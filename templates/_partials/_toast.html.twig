{# _toast.html.twig #}
{% set colors = {
    success: 'bg-zinc-900 dark:bg-zinc-100 text-zinc-100 dark:text-zinc-900',
    error:   'bg-red-600 text-white',
    info:    'bg-blue-600 text-white',
} %}

<div
    data-controller="toast"
    data-toast-duration-value="4000"
    role="status"
    class="flex items-center gap-2.5 px-4 py-2.5 rounded-lg shadow-lg text-sm font-medium
         transition-all duration-300 {{ colors[type ?? 'success'] }}"
>
    {{ message }}
    <button data-action="click->toast#dismiss" class="ml-1 opacity-60 hover:opacity-100 transition-opacity" aria-label="{{ 'toast.dismiss'|trans }}">
        <i class="fa-solid fa-xmark text-[14px]" aria-hidden="true"></i>
    </button>
</div>
