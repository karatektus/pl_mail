{# _toast.html.twig #}
{% set colors = {
    success: 'bg-zinc-900 dark:bg-zinc-100 text-zinc-100 dark:text-zinc-900',
    error:   'bg-red-600 text-white',
    info:    'bg-blue-600 text-white',
} %}

{% set progress_colors = {
    success: 'bg-white',
    error:   'bg-white',
    info:    'bg-white',
} %}

<div
    data-controller="toast"
    data-toast-duration-value="{{ extra.hide_after ?? 4000 }}"
    role="status"
    class="relative rounded-xl shadow-xl overflow-hidden min-w-[280px] max-w-sm
           {{ colors[type ?? 'success'] }}"
>
    {# ── flex row for content only ── #}
    <div class="flex items-center gap-3 px-5 py-3.5 text-base font-medium">
        {{ message }}
        {% if extra.undo_url is defined %}
            <span data-toast-target="countdown"></span>s
            <button
                data-controller="undo-send"
                data-undo-send-url-value="{{ extra.undo_url }}"
                data-undo-send-hide-after-value="{{ extra.hide_after ?? 4000 }}"
                data-action="click->undo-send#abort"
                class="ml-1 underline underline-offset-2 font-bold hover:opacity-70 transition-opacity cursor-pointer whitespace-nowrap"
            >
                Undo
            </button>
        {% endif %}

        <span class="ml-auto opacity-50 text-sm tabular-nums shrink-0">

    </span>

        <button
            data-action="click->toast#dismiss"
            class="ml-auto opacity-50 hover:opacity-100 transition-opacity cursor-pointer shrink-0"
            aria-label="{{ 'toast.dismiss'|trans }}"
        >
            <i class="fa-solid fa-xmark text-base" aria-hidden="true"></i>
        </button>
    </div>

</div>
