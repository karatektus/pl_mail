<header class="flex items-center gap-2 px-4 h-14 flex-shrink-0 pane relative z-20">

    {# Burger — mobile only #}
    <button
        type="button"
        class="md:hidden flex items-center justify-center w-9 h-9 rounded-lg
               text-ink-muted
               hover:bg-hover
               transition-colors flex-shrink-0"
        aria-label="{{ 'sidebar.nav.inbox'|trans }}"
        data-action="click->sidebar-drawer#toggle"
    >
        <i class="fa-solid fa-bars text-base" aria-hidden="true"></i>
    </button>

    {# Logo #}
    <a
        href="{{ path('app_mail_inbox') }}"
        class="flex items-center gap-2 flex-shrink-0 md:w-52 no-underline"
        aria-label="{{ 'app.name'|trans }}"
    >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="32" height="32" aria-hidden="true">
            <defs>
                <clipPath id="logo-clip">
                    <rect width="48" height="48" rx="10"/>
                </clipPath>
            </defs>
            <g clip-path="url(#logo-clip)" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <line x1="15" y1="10" x2="15" y2="38" stroke="#4285F4" stroke-width="5.5"/>
                <path d="M15 10 Q15 6 19 6 L25 6 Q31 6 31 12" stroke="#EA4335" stroke-width="5.5"/>
                <line x1="31" y1="12" x2="31" y2="26" stroke="#FBBC04" stroke-width="5.5"/>
                <path d="M31 26 Q31 30 25 30 L19 30 Q15 30 15 26" stroke="#34A853" stroke-width="5.5"/>
                <line x1="37" y1="7" x2="37" y2="26" stroke="#EA4335" stroke-width="5.5"/>
                <line x1="37" y1="26" x2="37" y2="35" stroke="#4285F4" stroke-width="5.5"/>
                <path d="M37 35 Q37 42 44 42" stroke="#FBBC04" stroke-width="5.5"/>
            </g>
        </svg>
        <span class="hidden sm:inline font-semibold text-ink text-sm tracking-wide">{{ 'app.name'|trans }}</span>
    </a>

    {# ── Search ────────────────────────────────────────────────────────── #}
    <div
        class="flex-1 max-w-2xl mx-auto relative"
        data-controller="search"
    >
        <div class="relative">
            <i class="fa-solid fa-magnifying-glass absolute left-3 top-2.5 text-gray-400 text-sm pointer-events-none" aria-hidden="true"></i>
            <input
                type="search"
                name="q"
                value="{{ app.request.query.get('q', '') }}"
                placeholder="{{ 'header.search.placeholder'|trans }}"
                autocomplete="off"
                data-search-target="input"
                data-action="keydown->search#onKeydown focus->search#onFocus input->search#onInput"
                class="w-full pl-10 pr-4 py-2 text-sm
                       bg-sunken
                       border border-transparent rounded-xl
                       text-ink
                       placeholder:text-ink-faint
                       focus:outline-none focus:ring-2 focus:ring-accent
                       focus:bg-field
                       transition-colors"
            >
        </div>

        {# Recent searches dropdown #}
        <div
            data-search-target="dropdown"
            class="hidden absolute left-0 right-0 top-full mt-1 z-50
                   bg-surface
                   border border-line
                   rounded-xl shadow-xl overflow-hidden"
        >
            <div class="flex items-center justify-between px-3 py-1.5 border-b border-line">
                <span class="text-[11px] font-semibold uppercase tracking-wider text-ink-faint">Recent searches</span>
                <button
                    type="button"
                    data-action="click->search#clearRecents"
                    class="text-[11px] text-gray-400 hover:text-ink-soft transition-colors"
                >
                    Clear
                </button>
            </div>
            <ul data-search-target="recentsList" class="py-1 max-h-56 overflow-y-auto"></ul>
        </div>
    </div>

    {# Right actions #}
    <div class="flex items-center gap-1 flex-shrink-0">
        {# User menu #}
        <div class="relative ml-1" data-controller="user-menu">
            <button id="user-menu-btn"
                    data-action="click->user-menu#toggle"
                    class="flex cursor-pointer items-center justify-center w-8 h-8 rounded-full bg-accent hover:ring-2 hover:ring-accent/60 hover:ring-offset-1 ring-offset-surface text-white text-xs font-semibold transition-all"
                    aria-label="{{ 'header.user_menu.label'|trans({ '%email%': app.user.email }) }}"
                    title="{{ app.user.email }}">
                {{ app.user.email | first | upper }}
            </button>

            <div id="user-menu" data-user-menu-target="menu"  class="hidden absolute right-0 mt-2 w-56 bg-surface border border-line rounded-xl shadow-lg py-1 z-[200]">
                <div class="px-4 py-2.5 border-b border-line">
                    <p class="text-xs text-gray-400">{{ 'header.user_menu.signed_in_as'|trans }}</p>
                    <p class="text-sm font-medium text-ink truncate">{{ app.user.email }}</p>
                </div>
                <a href="{{ path('app_settings_index') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-ink-soft hover:bg-hover">
                    <i class="fa-solid fa-gear w-4 text-gray-400" aria-hidden="true"></i>
                    {{ 'header.user_menu.settings'|trans }}
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_admin_dashboard') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-ink-soft hover:bg-hover">
                        <i class="fa-solid fa-gauge-high w-4 text-gray-400" aria-hidden="true"></i>
                        {{ 'header.user_menu.admin'|trans }}
                    </a>
                {% endif %}
                <a href="{{ path('app_logout') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-ink-soft hover:bg-hover">
                    <i class="fa-solid fa-right-from-bracket w-4 text-gray-400" aria-hidden="true"></i>
                    {{ 'header.user_menu.sign_out'|trans }}
                </a>
            </div>
        </div>

    </div>
</header>
