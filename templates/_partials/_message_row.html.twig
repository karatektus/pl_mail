{# _partials/_message_row.html.twig #}
<li class="group relative" data-controller="message-row" data-message-row-id-value="{{ message.id }}">
    <div class="flex items-center gap-3 pl-3 pr-4 py-2.5 cursor-pointer transition-colors
        {{ message.seenAt is null
    ? 'bg-white dark:bg-gray-900'
    : 'bg-gray-50/60 dark:bg-gray-950/40' }}
        hover:bg-gray-100 dark:hover:bg-gray-800/70 hover:shadow-sm"
    >
        {# Checkbox #}
        <input
            type="checkbox"
            data-action="click->message-row#toggleSelect"
            class="w-4 h-4 rounded border-gray-300 dark:border-gray-700 text-blue-600 focus:ring-blue-500 focus:ring-offset-0 cursor-pointer flex-shrink-0"
        >

        {# Star toggle #}
        <button
            type="button"
            data-action="click->message-row#toggleStar"
            class="flex-shrink-0 text-gray-300 dark:text-gray-600 hover:text-amber-400 transition-colors {{ message.starredAt is not null ? 'text-amber-400' : '' }}"
            aria-label="{{ message.starredAt is not null ? 'Unstar' : 'Star' }} this message"
        >
            <svg class="w-[18px] h-[18px]" fill="{{ message.starredAt is not null ? 'currentColor' : 'none' }}" stroke="currentColor" stroke-width="1.6" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.95a1 1 0 00.95.69h4.155c.969 0 1.371 1.24.588 1.81l-3.363 2.44a1 1 0 00-.364 1.118l1.285 3.95c.3.921-.755 1.688-1.539 1.118l-3.363-2.44a1 1 0 00-1.176 0l-3.363 2.44c-.783.57-1.838-.197-1.539-1.118l1.285-3.95a1 1 0 00-.363-1.118l-3.364-2.44c-.782-.57-.38-1.81.588-1.81h4.155a1 1 0 00.951-.69l1.285-3.95z"/>
            </svg>
        </button>

        {# Clickable row content #}
        <a
            href="{{ path('app_mail_message', { id: message.id }) }}"
            data-action="click->mail-pane#open"
            class="flex items-center gap-4 flex-1 min-w-0"
        >
            {# Sender #}
            <span class="w-40 flex-shrink-0 truncate text-sm
                {{ message.seenAt is null ? 'font-semibold text-gray-900 dark:text-gray-100' : 'font-normal text-gray-600 dark:text-gray-400' }}"
            >
                {{ message.fromName ?: message.fromAddress }}
            </span>

            {# Subject + snippet, single line, ellipsis #}
            <span class="flex-1 min-w-0 truncate text-sm">
                <span class="{{ message.seenAt is null ? 'font-semibold text-gray-900 dark:text-gray-100' : 'font-normal text-gray-700 dark:text-gray-300' }}">
                    {{ message.subject ?: '(no subject)' }}
                </span>
                <span class="text-gray-400 dark:text-gray-600">
                    — {{ message.bodyText|striptags|slice(0, 100) }}
                </span>
            </span>
        </a>

        {# Date — hidden on hover, replaced by quick actions #}
        <span class="flex-shrink-0 w-16 text-right text-xs text-gray-400 dark:text-gray-600 group-hover:hidden">
            {% if message.receivedAt %}
                {% if message.receivedAt|date('Y-m-d') == 'now'|date('Y-m-d') %}
                    {{ message.receivedAt|date('g:i a') }}
                {% else %}
                    {{ message.receivedAt|date('M j') }}
                {% endif %}
            {% endif %}
        </span>

        {# Hover quick actions — visual only for now #}
        <div class="hidden group-hover:flex items-center gap-1 flex-shrink-0">
            <button type="button" data-action="click->message-row#archive" title="Archive"
                    class="p-1.5 rounded-lg text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 01-2-2V5a1 1 0 011-1h16a1 1 0 011 1v1a2 2 0 01-2 2M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8M10 12h4"/>
                </svg>
            </button>
            <button type="button" data-action="click->message-row#delete" title="Delete"
                    class="p-1.5 rounded-lg text-gray-400 hover:text-red-600 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
            </button>
            <button type="button" data-action="click->message-row#snooze" title="Snooze"
                    class="p-1.5 rounded-lg text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </button>
            <button type="button" data-action="click->message-row#markRead" title="Mark as {{ message.seenAt is null ? 'read' : 'unread' }}"
                    class="p-1.5 rounded-lg text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
                {% if message.seenAt is null %}
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                {% else %}
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        <circle cx="18" cy="6" r="3" fill="currentColor" stroke="none"/>
                    </svg>
                {% endif %}
            </button>
        </div>
    </div>
</li>
