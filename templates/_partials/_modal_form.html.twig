{% set submit_label = submit_label ?? 'form.submit'|trans %}
{% set cancel_label = cancel_label ?? 'form.cancel'|trans %}
{% set danger       = danger ?? false %}

<turbo-frame id="modal">
    <template data-modal-frame-title>{{ title ?? '' }}</template>

    {{ form_start(form, {
        attr: {
            'data-turbo-frame': 'modal',
            class: 'flex flex-col min-h-0',
        }
    }) }}

    {# ── Body ── #}
    <div class="px-5 py-5 space-y-4 overflow-y-auto">

        {# Global form errors #}
        {% if form.vars.errors|length %}
            <div
                role="alert"
                class="flex items-start gap-2.5 rounded-lg bg-red-50 dark:bg-red-950/60 border border-red-200 dark:border-red-800/70 px-3.5 py-3 text-sm text-danger"
            >
                <i class="fa-solid fa-circle-exclamation mt-0.5 shrink-0 text-danger" aria-hidden="true"></i>
                <div class="space-y-0.5">
                    {% for error in form.vars.errors %}
                        <p class="leading-snug">{{ error.message }}</p>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {{ form_widget(form) }}

    </div>

    {# ── Footer ── #}
    <div class="flex items-center justify-end gap-2 px-5 py-3.5 border-t border-zinc-200 dark:border-zinc-700/60 bg-zinc-50/80 dark:bg-zinc-800/40 rounded-b-xl shrink-0">
        <button
            type="button"
            data-action="click->modal#close"
            class="inline-flex items-center justify-center h-8 px-3.5 rounded-lg text-sm font-medium
               text-ink-soft
               bg-field
               border border-zinc-300 dark:border-zinc-600/80
               hover:bg-zinc-50 dark:hover:bg-zinc-700
               focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-1
               transition-colors duration-100"
        >{{ cancel_label }}</button>

        <button
            type="submit"
            class="inline-flex items-center justify-center h-8 px-3.5 rounded-lg text-sm font-medium text-white
               focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-1
               transition-colors duration-100
               {% if danger %}
                 bg-red-600 hover:bg-red-700 active:bg-red-800 focus-visible:ring-red-500
               {% else %}
                 bg-accent hover:bg-accent-strong active:bg-blue-800 focus-visible:ring-blue-500
               {% endif %}"
        >{{ submit_label }}</button>
    </div>

    {{ form_end(form) }}
</turbo-frame>
