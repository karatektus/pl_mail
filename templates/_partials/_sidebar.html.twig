{% macro unread_badge(count) %}
    {% if count > 0 %}
        <span class="text-xs font-semibold px-1.5 py-0.5 rounded-full bg-blue-600 text-white">
            {{ count }}
        </span>
    {% endif %}
{% endmacro %}

{% macro label_dot(color) %}
    <span class="w-2.5 h-2.5 rounded-full shrink-0
        {{ {
        'gray':   'bg-ink-faint',
        'red':    'bg-red-500',
        'orange': 'bg-orange-500',
        'amber':  'bg-amber-500',
        'green':  'bg-green-500',
        'teal':   'bg-teal-500',
        'blue':   'bg-blue-500',
        'violet': 'bg-violet-500',
        'pink':   'bg-pink-500',
    }[color ?? 'gray'] ?? 'bg-ink-faint' }}"
          aria-hidden="true"></span>
{% endmacro %}

{% macro label_node(node, depth, drawerClose) %}
    {% import _self as macros %}

    {% if node.children|length > 0 %}
        <details class="group/tree" open>
            <summary class="flex items-center gap-1 px-3 py-1.5 rounded-lg cursor-pointer list-none
                            hover:bg-hover transition-colors"
                     style="padding-left: {{ 12 + depth * 14 }}px">
                <i class="fa-solid fa-chevron-right text-[9px] text-ink-faint w-3
                          transition-transform group-open/tree:rotate-90" aria-hidden="true"></i>
                {{ macros.label_dot(node.color) }}
                <a href="{{ path('app_mail_label_path', { path: node.path }) }}"
                   class="flex-1 flex items-center justify-between gap-2 truncate"
                   data-sidebar-target="link"
                   data-action="{{ drawerClose }}">
                    <span class="truncate">{{ node.name }}</span>
                    {{ macros.unread_badge(sidebarCounts.forNode(node)) }}
                </a>
            </summary>
            <div class="space-y-0.5">
                {% for child in node.children %}
                    {{ macros.label_node(child, depth + 1, drawerClose) }}
                {% endfor %}
            </div>
        </details>
    {% else %}
        <a href="{{ path('app_mail_label_path', { path: node.path }) }}"
           class="flex items-center gap-2 px-3 py-1.5 rounded-lg transition-colors
                  hover:bg-hover"
           style="padding-left: {{ 12 + depth * 14 + 16 }}px"
           data-sidebar-target="link"
           data-action="{{ drawerClose }}">
            {{ macros.label_dot(node.color) }}
            <span class="flex-1 flex items-center justify-between gap-2 truncate">
                <span class="truncate">{{ node.name }}</span>
                {{ macros.unread_badge(sidebarCounts.forNode(node)) }}
            </span>
        </a>
    {% endif %}
{% endmacro %}

{% import _self as macros %}

{#
_drawerMode is set to true when this sidebar is rendered inside the mobile drawer.
When true, nav links also dispatch a close action to the parent sidebar-drawer controller.
#}
{% set _drawerClose = _drawerMode is defined and _drawerMode ? 'click->sidebar-drawer#close' : '' %}

<aside id="{{ _drawerMode is defined and _drawerMode ? 'sidebar-drawer-inner' : 'sidebar' }}"
       {% if not (_drawerMode is defined and _drawerMode) %}data-turbo-permanent{% endif %}
       data-controller="sidebar"
       class="flex flex-col w-56 h-full flex-shrink-0 bg-surface rounded-pane shadow-pop border border-line">

    {# Compose #}
    <div class="px-3 py-3 border-b border-line">
        <a href="{{ path('app_compose_new') }}"
           data-turbo-frame="compose_dock"
           data-action="{{ _drawerClose }}"
           class="w-full flex items-center justify-center gap-2 bg-accent hover:bg-accent-strong text-white text-sm font-medium rounded-lg px-3 py-2 transition-colors">
            <i class="fa-solid fa-plus w-4 h-4" aria-hidden="true"></i>
            {{ 'sidebar.compose'|trans }}
        </a>
    </div>

    {# Nav #}
    <nav class="flex-1 overflow-y-auto px-2 py-2 space-y-0.5 text-sm">

        <a href="{{ path('app_mail_inbox') }}"
           class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg transition-colors"
           data-sidebar-target="link"
           data-action="{{ _drawerClose }}"
        >
            <span class="flex items-center gap-2">
                <i class="fa-solid fa-inbox w-4" aria-hidden="true"></i>
                {{ 'sidebar.nav.inbox'|trans }}
            </span>
            {{ macros.unread_badge(sidebarCounts.forRole(enum('App\\Domain\\Enum\\LabelRole').Inbox)) }}
        </a>

        <a href="{{ path('app_mail_starred') }}"
           class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg transition-colors"
           data-sidebar-target="link"
           data-action="{{ _drawerClose }}"
        >
            <span class="flex items-center gap-2">
                <i class="fa-solid fa-star w-4" aria-hidden="true"></i>
                {{ 'sidebar.nav.starred'|trans }}
            </span>
            {{ macros.unread_badge(sidebarCounts.forStarred()) }}
        </a>

        <a href="{{ path('app_mail_sent') }}"
           class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg transition-colors"
           data-sidebar-target="link"
           data-action="{{ _drawerClose }}"
        >
            <span class="flex items-center gap-2">
                <i class="fa-solid fa-paper-plane w-4" aria-hidden="true"></i>
                {{ 'sidebar.nav.sent'|trans }}
            </span>
            {{ macros.unread_badge(sidebarCounts.forRole(enum('App\\Domain\\Enum\\LabelRole').Sent)) }}
        </a>

        <a href="{{ path('app_mail_drafts') }}"
           class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg transition-colors"
           data-sidebar-target="link"
           data-action="{{ _drawerClose }}"
        >
            <span class="flex items-center gap-2">
                <i class="fa-solid fa-file-lines w-4" aria-hidden="true"></i>
                {{ 'sidebar.nav.drafts'|trans }}
            </span>
            {{ macros.unread_badge(sidebarCounts.forRole(enum('App\\Domain\\Enum\\LabelRole').Drafts)) }}
        </a>
        {% if sidebarCounts.hasVisibleArchive %}
            <a href="{{ path('app_mail_archive') }}"
               class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg transition-colors"
               data-sidebar-target="link"
               data-action="{{ _drawerClose }}">
                <i class="fa-solid fa-box-archive w-4 text-sm" aria-hidden="true"></i>
                <span class="flex-1 flex items-center justify-between gap-2">
            <span>{{ 'sidebar.nav.archive'|trans }}</span>
            {{ macros.unread_badge(sidebarCounts.forRole(enum('App\\Domain\\Enum\\LabelRole').Archive)) }}
        </span>
            </a>
        {% endif %}
        <a href="{{ path('app_mail_trash') }}"
           class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg transition-colors"
           data-sidebar-target="link"
           data-action="{{ _drawerClose }}"
        >
            <span class="flex items-center gap-2">
                <i class="fa-solid fa-trash w-4" aria-hidden="true"></i>
                {{ 'sidebar.nav.trash'|trans }}
            </span>
            {{ macros.unread_badge(sidebarCounts.forRole(enum('App\\Domain\\Enum\\LabelRole').Trash)) }}
        </a>

        {# Labels section #}
        <div class="pt-4 pb-1 px-3 flex items-center justify-between">
            <span class="text-xs font-semibold text-ink-faint uppercase tracking-wider">{{ 'sidebar.labels.heading'|trans }}</span>
            <button
                data-controller="modal"
                data-action="click->modal#open {{ _drawerClose }}"
                data-modal-title-value="{{ 'sidebar.labels.add'|trans }}"
                data-modal-src-value="{{ path('app_label_new') }}"
                class="p-1 rounded hover:bg-hover text-gray-400 hover:text-ink-soft transition-colors cursor-pointer"
                aria-label="{{ 'sidebar.labels.add'|trans }}"
            >
                <i class="fa-solid fa-plus w-3.5 h-3.5" aria-hidden="true"></i>
            </button>
        </div>

        <div id="{{ _drawerMode is defined and _drawerMode ? 'label-list-drawer' : 'label-list' }}" class="space-y-0.5">
            {% set labelTree = sidebarCounts.userLabelTree() %}
            {% if labelTree|length == 0 %}
                <p class="px-3 py-1.5 text-xs text-ink-faint">{{ 'sidebar.labels.none'|trans }}</p>
            {% else %}
                {% for node in labelTree %}
                    {{ macros.label_node(node, 0, _drawerClose) }}
                {% endfor %}
            {% endif %}
        </div>

        {# Accounts section #}
        <div class="pt-4 pb-1 px-3 flex items-center justify-between">
            <span class="text-xs font-semibold text-ink-faint uppercase tracking-wider">{{ 'sidebar.accounts.heading'|trans }}</span>
            <button
                data-controller="modal"
                data-action="click->modal#open {{ _drawerClose }}"
                data-modal-title-value="{{ 'sidebar.accounts.add'|trans }}"
                data-modal-src-value="{{ path('app_account_new') }}"
                class="p-1 rounded hover:bg-hover text-gray-400 hover:text-ink-soft transition-colors cursor-pointer"
                aria-label="{{ 'sidebar.accounts.add'|trans }}"
            >
                <i class="fa-solid fa-plus w-3.5 h-3.5" aria-hidden="true"></i>
            </button>
        </div>

        <div id="{{ _drawerMode is defined and _drawerMode ? 'account-list-drawer' : 'account-list' }}" class="space-y-0.5">
            {% include '_partials/_account_list.html.twig' with { _drawerClose: _drawerClose } %}
        </div>

    </nav>
</aside>
