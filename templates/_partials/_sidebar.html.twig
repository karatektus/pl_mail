{% macro unread_badge(count) %}
    {% if count > 0 %}
        <span class="text-xs font-semibold px-1.5 py-0.5 rounded-full bg-blue-600 text-white">
            {{ count }}
        </span>
    {% endif %}
{% endmacro %}

{% import _self as macros %}

{#
_drawerMode is set to true when this sidebar is rendered inside the mobile drawer.
When true, nav links also dispatch a close action to the parent sidebar-drawer controller.
#}
{% set _drawerClose = _drawerMode is defined and _drawerMode ? 'click->sidebar-drawer#close' : '' %}

<aside id="{{ _drawerMode is defined and _drawerMode ? 'sidebar-drawer-inner' : 'sidebar' }}"
       {% if not (_drawerMode is defined and _drawerMode) %}data-turbo-permanent{% endif %}
       data-controller="sidebar"
       class="flex flex-col w-56 h-full flex-shrink-0 bg-white dark:bg-gray-900 rounded-2xl shadow-lg shadow-black/5 dark:shadow-black/30 border border-gray-200/60 dark:border-gray-800/60">

    {# Compose #}
    <div class="px-3 py-3 border-b border-gray-100 dark:border-gray-800">
        <a href="{{ path('app_compose_new') }}"
           data-turbo-frame="compose_dock"
           data-action="{{ _drawerClose }}"
           class="w-full flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg px-3 py-2 transition-colors">
            <i class="fa-solid fa-plus w-4 h-4" aria-hidden="true"></i>
            {{ 'sidebar.compose'|trans }}
        </a>
    </div>

    {# Nav #}
    <nav class="flex-1 overflow-y-auto px-2 py-2 space-y-0.5 text-sm">

        <a href="{{ path('app_mail_inbox') }}"
           class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg transition-colors"
           data-sidebar-target="link"
           data-action="{{ _drawerClose }}"
        >
            <span class="flex items-center gap-2">
                <i class="fa-solid fa-inbox w-4" aria-hidden="true"></i>
                {{ 'sidebar.nav.inbox'|trans }}
            </span>
            {{ macros.unread_badge(sidebarCounts.forSpecialUse(enum('App\\Domain\\Enum\\MailboxSpecialUse').INBOX)) }}
        </a>

        <a href="{{ path('app_mail_starred') }}"
           class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg transition-colors"
           data-sidebar-target="link"
           data-action="{{ _drawerClose }}"
        >
            <span class="flex items-center gap-2">
                <i class="fa-solid fa-star w-4" aria-hidden="true"></i>
                {{ 'sidebar.nav.starred'|trans }}
            </span>
            {{ macros.unread_badge(sidebarCounts.forStarred()) }}
        </a>

        <a href="{{ path('app_mail_sent') }}"
           class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg transition-colors"
           data-sidebar-target="link"
           data-action="{{ _drawerClose }}"
        >
            <span class="flex items-center gap-2">
                <i class="fa-solid fa-paper-plane w-4" aria-hidden="true"></i>
                {{ 'sidebar.nav.sent'|trans }}
            </span>
            {{ macros.unread_badge(sidebarCounts.forSpecialUse(enum('App\\Domain\\Enum\\MailboxSpecialUse').SENT)) }}
        </a>

        <a href="{{ path('app_mail_drafts') }}"
           class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg transition-colors"
           data-sidebar-target="link"
           data-action="{{ _drawerClose }}"
        >
            <span class="flex items-center gap-2">
                <i class="fa-solid fa-file-lines w-4" aria-hidden="true"></i>
                {{ 'sidebar.nav.drafts'|trans }}
            </span>
            {{ macros.unread_badge(sidebarCounts.forSpecialUse(enum('App\\Domain\\Enum\\MailboxSpecialUse').DRAFTS)) }}
        </a>

        <a href="{{ path('app_mail_trash') }}"
           class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg transition-colors"
           data-sidebar-target="link"
           data-action="{{ _drawerClose }}"
        >
            <span class="flex items-center gap-2">
                <i class="fa-solid fa-trash w-4" aria-hidden="true"></i>
                {{ 'sidebar.nav.trash'|trans }}
            </span>
            {{ macros.unread_badge(sidebarCounts.forSpecialUse(enum('App\\Domain\\Enum\\MailboxSpecialUse').TRASH)) }}
        </a>

        {# Accounts section #}
        <div class="pt-4 pb-1 px-3 flex items-center justify-between">
            <span class="text-xs font-semibold text-gray-400 dark:text-gray-600 uppercase tracking-wider">{{ 'sidebar.accounts.heading'|trans }}</span>
            <button
                data-controller="modal"
                data-action="click->modal#open {{ _drawerClose }}"
                data-modal-title-value="{{ 'sidebar.accounts.add'|trans }}"
                data-modal-src-value="{{ path('app_account_new') }}"
                class="p-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors cursor-pointer"
                aria-label="{{ 'sidebar.accounts.add'|trans }}"
            >
                <i class="fa-solid fa-plus w-3.5 h-3.5" aria-hidden="true"></i>
            </button>
        </div>

        <div id="{{ _drawerMode is defined and _drawerMode ? 'account-list-drawer' : 'account-list' }}" class="space-y-0.5">
            {% include '_partials/_account_list.html.twig' with { _drawerClose: _drawerClose } %}
        </div>

    </nav>
</aside>
