{#
_label_menu.html.twig
─────────────────────────────────────────────────────────────────────────────
"Label as" dropdown for the list toolbar and the thread view toolbar.

Variables:
  labels        Label[]   flat list of the user's custom labels (role null),
                          pre-ordered; indentation derives from label.depth
  targetType    string    "thread" | "message"
  targetId      int|null  when null the Stimulus controller resolves selected
                          rows from the list instead (bulk mode)
  activeLabels  int[]     ids of labels currently attached (single-target mode)
#}
<div data-controller="label-menu"
     data-label-menu-target-type-value="{{ targetType }}"
     {% if targetId is defined and targetId is not null %}data-label-menu-target-id-value="{{ targetId }}"{% endif %}
     class="relative">

    <button type="button"
            data-action="click->label-menu#toggle"
            aria-label="{{ 'toolbar.actions.label'|trans }}"
            class="group relative flex items-center justify-center w-8 h-8 rounded-full
                   text-ink-muted
                   hover:text-ink
                   hover:bg-hover
                   transition-colors duration-100 cursor-pointer">
        <i class="fa-solid fa-tag text-sm" aria-hidden="true"></i>
    </button>

    <div data-label-menu-target="panel"
         class="hidden absolute right-0 top-full mt-1 z-30 w-56 max-h-72 overflow-y-auto rounded-xl
                bg-pane-soft backdrop-blur-xl
                border border-line
                shadow-pop py-1">

        {% if labels|length == 0 %}
            <p class="px-3 py-2 text-xs text-ink-faint">{{ 'label.menu.empty'|trans }}</p>
        {% else %}
            {% for label in labels %}
                <button type="button"
                        data-action="click->label-menu#toggleLabel"
                        data-label-menu-label-id-param="{{ label.id }}"
                        data-label-id="{{ label.id }}"
                        data-attached="{{ activeLabels is defined and label.id in activeLabels ? 'true' : 'false' }}"
                        class="w-full flex items-center gap-2 px-3 py-1.5 text-sm text-left
                               text-ink-soft
                               hover:bg-hover transition-colors cursor-pointer"
                        style="padding-left: {{ 12 + label.depth * 14 }}px">
                    <i data-label-menu-target="check"
                       class="fa-solid fa-check w-3.5 text-accent
                              {{ activeLabels is defined and label.id in activeLabels ? '' : 'invisible' }}"
                       aria-hidden="true"></i>
                    <span class="truncate">{{ label.name }}</span>
                </button>
            {% endfor %}
        {% endif %}

        <div class="border-t border-line mt-1 pt-1">
            <button type="button"
                    data-controller="modal"
                    data-action="click->modal#open"
                    data-modal-title-value="{{ 'sidebar.labels.add'|trans }}"
                    data-modal-src-value="{{ path('app_label_new') }}"
                    class="w-full flex items-center gap-2 px-3 py-1.5 text-sm text-left
                           text-ink-soft
                           hover:bg-hover transition-colors cursor-pointer">
                <i class="fa-solid fa-plus w-3.5" aria-hidden="true"></i>
                {{ 'label.menu.create'|trans }}
            </button>
        </div>
    </div>
</div>
