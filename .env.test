# .env.test — committed defaults for the `test` environment (E2E + PHPUnit).
# Real environment variables and .env.test.local override anything here.
# DO NOT put real secrets in this file; these values are throwaway CI defaults.

APP_ENV=test
APP_DEBUG=1

# Fixed so CSRF tokens are stable within a run. Test-only value.
APP_SECRET=282065e0f71bf96c0dbcf0496c1f5d3e

# Throwaway libsodium key for the encrypted_string Doctrine type. Test-only.
# Regenerate with: php -r 'echo base64_encode(sodium_crypto_secretbox_keygen());'
APP_ENCRYPTION_KEY=emL6R8zs0pSXCVV2HvVvbFubriWJIla7kgnqSGqCJ8E=

# No real mail is sent, and async work is collected but not processed so the
# suite never needs a running worker.
MAILER_DSN=null://null
MESSENGER_TRANSPORT_DSN=in-memory://

# Single source of truth for the seeded test user. The seed command, the
# login template prefill, and the Playwright specs all read these.
APP_DEV_USER_EMAIL=e2e@plmail.test
APP_DEV_USER_PASSWORD=e2e-password-change-me

# Local default DB. CI overrides DATABASE_URL to point at its Postgres service.
DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=18&charset=utf8"
